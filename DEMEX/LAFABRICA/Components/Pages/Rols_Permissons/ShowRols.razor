@page "/roles"
@attribute [Authorize]
@using LAFABRICA.Data.DB
@using LAFABRICA.Models.Interface
@inject IRolService service
@inject NavigationManager nav

<PageTitle>Roles</PageTitle>

<Modal @ref="modal" IsVerticallyCentered="true" Size="ModalSize.Large" />
<ConfirmDialog @ref="dialog" />
<Toasts class="p-3" AutoHide="true" Delay="4000" Placement="ToastsPlacement.TopRight" />

@if (roles == null)
{
    <div class="d-flex justify-content-center">
        <Spinner Type="SpinnerType.Border" Size="SpinnerSize.Large" />
    </div>
}
else if (!roles.Any())
{
    <div>
        <Alert Color="AlertColor.Primary" class="d-flex justify-content-between align-items-center">
            <div>
                <Icon Name="IconName.InfoCircleFill" class="me-2" />
                <strong>No hay roles registrados</strong>
            </div>
            <button class="btn btn-outline-primary" @onclick="ShowCreateModal">
                <Icon Name="IconName.PlusLg" /> Nuevo Rol
            </button>
        </Alert>
    </div>
}
else
{
    <div class="container mt-2">
        <div class="card shadow">
            <div class="card-header">
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <h3><Icon Name="IconName.KeyFill"></Icon> Gestión de Roles</h3>
                    <button class="btn text-white" style="background-color: #0f54a1;" @onclick="ShowCreateModal">
                        <Icon Name="IconName.PlusLg"></Icon> Nuevo Rol
                    </button>
                </div>
            </div>

            <div class="card-body text-center">
                <div class="row">
                    <div class="col-12 table-responsive" style="max-height: 370px; overflow-y: auto;">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Rol</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var rl in roles.Select((r, index) => new { r, index }))
                                {
                                    <tr>
                                        <td>@(rl.index + 1)</td>
                                        <td>@TranslateRoleName(rl.r.Name)</td>
                                        <td>
                                            <button class="btn btn-show me-2" @onclick="() => ShowPermissions(rl.r)">
                                                <Icon Class="icon-show" Name="IconName.KeyFill"></Icon>
                                            </button>

                                            @if (!IsProtectedRole(rl.r))
                                            {
                                                <button class="btn btn-delete" @onclick="() => DeleteRole(rl.r)">
                                                    <Icon Name="IconName.Trash" Color="IconColor.Danger"></Icon>
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal para crear nuevo rol -->
@if (showCreateModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Agregar nuevo rol</h5>
                    <button type="button" class="btn-close" @onclick="CloseCreateModal"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-info">
                        <Icon Name="IconName.InfoCircleFill" class="me-2" />
                        Al crear este rol se le asignarán <strong>permisos predeterminados</strong>.
                        Podrás modificarlos luego desde la tabla de roles.
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Nombre del rol</label>
                        <InputText class="form-control" @bind-Value="newRoleName" placeholder="Ejemplo: Supervisor, Vendedor..." />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" @onclick="CloseCreateModal">Cancelar</button>
                    <button class="btn text-white" @onclick="CreateRole" style="background-color: #0f54a1">Guardar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Rol>? roles;
    private Modal modal = default!;
    private ConfirmDialog dialog = default!;
    private bool showCreateModal = false;
    private string newRoleName = string.Empty;

    [Inject] protected ToastService ToastService { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        await LoadRoles();
    }

    private async Task LoadRoles()
    {
        roles = (await service.GetAllRols()).ToList();
    }

    private async Task ShowPermissions(Rol rol)
    {
        var parameters = new Dictionary<string, object> { { "Rol", rol } };
        await modal.ShowAsync<RolePermissionsView>(title: $"Permisos del Rol: {rol.Name}", parameters: parameters);
    }

    private string TranslateRoleName(string name)
    {
        return name.ToUpper() switch
        {
            "CLIENTS" => "Clientes",
            "CLIENTS_PAYMENTS" => "Pagos de Clientes",
            "INVENTORY" => "Inventario",
            "MATERIAL" => "Materiales",
            "ORDERS" => "Órdenes",
            "PRODUCTS" => "Productos",
            "REPORTS" => "Reportes",
            "ROLS" => "Roles",
            "SUPPLIERS" => "Proveedores",
            "USERS" => "Usuarios",
            "WORKERS_PAYMENTS" => "Pagos de Empleados",
            "ADMIN" => "Administrador",
            _ => name
        };
    }

    private bool IsProtectedRole(Rol rol)
    {
        var roleName = rol.Name.Trim().ToLower();
        return roleName == "admin" || roleName == "administrador";
    }

    private void ShowCreateModal()
    {
        showCreateModal = true;
        newRoleName = string.Empty;
    }

    private void CloseCreateModal()
    {
        showCreateModal = false;
    }

    private async Task CreateRole()
    {
        if (string.IsNullOrWhiteSpace(newRoleName))
        {
            ToastService.Notify(new(ToastType.Warning, "Debe ingresar un nombre para el rol."));
            return;
        }

        try
        {
            var newRole = new Rol { Name = newRoleName.Trim() };
            await service.Create(newRole);
            ToastService.Notify(new(ToastType.Success, $"Rol '{newRole.Name}' creado correctamente."));
            CloseCreateModal();
            await LoadRoles();
        }
        catch (Exception ex)
        {
            ToastService.Notify(new(ToastType.Danger, $"Error al crear rol: {ex.Message}"));
        }
    }

    private async Task DeleteRole(Rol rol)
    {
        if (IsProtectedRole(rol))
        {
            ToastService.Notify(new(ToastType.Warning, "El rol Administrador no puede eliminarse."));
            return;
        }

        var options = new ConfirmDialogOptions
        {
            YesButtonText = "Eliminar",
            YesButtonColor = ButtonColor.Danger,
            NoButtonText = "Cancelar",
            NoButtonColor = ButtonColor.Secondary
        };

        var confirm = await dialog.ShowAsync(
            title: "Eliminar rol",
            message1: $"¿Deseas eliminar el rol '{rol.Name}'?",
            message2: "Esta acción es irreversible.",
            confirmDialogOptions: options);

        if (confirm)
        {
            try
            {
                await service.Delete(rol.Id);
                await LoadRoles();
                ToastService.Notify(new(ToastType.Success, $"Rol '{rol.Name}' eliminado correctamente."));
            }
            catch (Exception ex)
            {
                ToastService.Notify(new(ToastType.Danger, $"Error al eliminar rol: {ex.Message}"));
            }
        }
    }
}
