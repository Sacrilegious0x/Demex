@page "/pagos/empleados"
@attribute [Authorize]
@using LAFABRICA.Data.DB
@using LAFABRICA.Models
@using LAFABRICA.Models.Interface
@using LAFABRICA.Services.Auth
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject IEmployeePaymentService paymentService
@inject NavigationManager nav

<PageTitle>Pagos a empleados</PageTitle>

<Modal @ref="modal" IsVerticallyCentered="true" Size="ModalSize.Large" />
<Toasts class="p-3" AutoHide="true" Delay="4000" Placement="ToastsPlacement.TopRight" />
<ConfirmDialog @ref="dialog" />

@if (user == null)
{
    <div class="text-center p-5">
        <Spinner Color="SpinnerColor.Primary" />
        <p>Cargando autenticación...</p>
    </div>
}
else if (!HasPermission("Workers_Payments", DemexClaims.View))
{
    <Alert Color="AlertColor.Warning" class="mt-4">
        <Icon Name="IconName.ExclamationTriangleFill" class="me-2" />
        <strong>No tienes permiso</strong> para acceder a la gestión de pagos a empleados.
    </Alert>
}
else if (payments == null)
{
    <div class="d-flex justify-content-center">
        <Spinner Type="SpinnerType.Border" Size="SpinnerSize.Large" />
    </div>
}
else if (!payments.Any())
{
    <div>
        <Alert Color="AlertColor.Primary" class="d-flex justify-content-between align-items-center">
            <div>
                <Icon Name="IconName.InfoCircleFill" class="me-2" />
                <strong>No hay pagos registrados</strong>
            </div>
            @if (HasPermission("Workers_Payments", DemexClaims.Create))
            {
                <a class="btn btn-outline-primary" href="/pagos/empleados/crear">
                    <Icon Name="IconName.PlusLg" /> Registrar Pago
                </a>
            }
        </Alert>
    </div>
}
else
{
    <div class="container mt-2">
        <div class="card">
            <div class="card-header">
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <h3>
                        <Icon Name="IconName.CashStack"></Icon> Gestión de Pagos a Empleados
                    </h3>

                    @if (HasPermission("Workers_Payments", DemexClaims.Create))
                    {
                        <a id="nuevoPagoEmpleado" class="btn text-white" href="/pagos/empleados/crear" style="background-color: #0f54a1;">
                            <Icon Name="IconName.PlusLg"></Icon> Nuevo Pago
                        </a>
                    }
                </div>

                <div class="d-flex justify-content-sm-start align-items-center gap-3 mt-3">
                    <div class="d-flex align-items-center border rounded px-2">
                        <Icon Name="IconName.Search" class="text-secondary me-2" />
                        <input type="text" class="form-control border-0"
                               @bind="searchText" @bind:event="oninput"
                               placeholder="Buscar empleado..." style="box-shadow:none;" />
                    </div>

                    <div class="d-flex align-items-center gap-2">
                        <Icon Name="IconName.Funnel" class="text-secondary" />
                        <InputSelect class="form-select" @bind-Value="selectedState">
                            <option value="">Todos los estados</option>
                            <option value="Pendiente">Pendiente</option>
                            <option value="Pagado">Pagado</option>
                            <option value="Anulado">Anulado</option>
                        </InputSelect>
                    </div>
                </div>
            </div>

            <div class="card-body text-center">
                <div class="row">
                    <div class="col-12 table-responsive" style="max-height: 370px; overflow-y: auto;">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Empleado</th>
                                    <th>Fecha</th>
                                    <th>Descripción</th>
                                    <th>Estado</th>
                                    <th>Total</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in filteredPayments.Select((p, index) => new { p, index }))
                                {
                                    <tr>
                                        <td>@(item.index + 1)</td>
                                        <td>@item.p.Employee?.Name</td>
                                        <td>@item.p.Date.ToString("dd/MM/yyyy")</td>
                                        <td>@item.p.Description</td>
                                        <td>
                                            @if (item.p.State == "Pagado")
                                            {
                                                <span class="badge bg-success">@item.p.State</span>
                                            }
                                            else if (item.p.State == "Pendiente")
                                            {
                                                <span class="badge bg-warning text-dark">@item.p.State</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">@item.p.State</span>
                                            }
                                        </td>
                                        <td>₡@item.p.TotalAmount?.ToString("N2")</td>
                                        <td>
                                            @if (HasPermission("Workers_Payments", DemexClaims.View))
                                            {
                                                <button class="btn btn-show" @onclick="() => ViewPaymentDetails(item.p)">
                                                    <Icon Name="IconName.Eye" Class="icon-show"></Icon>
                                                </button>
                                            }

                                            @if (HasPermission("Workers_Payments", DemexClaims.Edit))
                                            {
                                                <button id="edit-@item.p.Id" class="btn btn-edit" @onclick="() => EditPayment(item.p)">
                                                    <Icon Name="IconName.PencilSquare" Class="icon-edit"></Icon>
                                                </button>
                                            }

                                            @if (HasPermission("Workers_Payments", DemexClaims.Delete))
                                            {
                                                <button class="btn btn-delete" @onclick="() => DeletePayment(item.p)">
                                                    <Icon Name="IconName.Trash" Color="IconColor.Danger"></Icon>
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Inject] protected ToastService ToastService { get; set; } = default!;
    [CascadingParameter] private Task<AuthenticationState>? authenticationStateTask { get; set; }

    private ClaimsPrincipal? user;
    private string selectedState = "";
    private string searchText = string.Empty;
    private List<EmployeePayment>? payments;
    private ConfirmDialog dialog = default!;
    private Modal modal = default!;

    private IEnumerable<EmployeePayment> filteredPayments =>
        payments?
            .Where(p => string.IsNullOrEmpty(selectedState) || p.State == selectedState)
            .Where(p => string.IsNullOrEmpty(searchText) ||
                        p.Employee!.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(p => p.Date)
        ?? Enumerable.Empty<EmployeePayment>();

    private bool HasPermission(string module, string action)
        => user?.HasClaim($"can_{module.ToUpper()}_{action}", "True") ?? false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await authenticationStateTask!;
        user = authState.User;
        await LoadPayments();
    }

    private async Task LoadPayments()
    {
        payments = (await paymentService.GetAllPaymentsAsync()).ToList();
    }

    private async Task DeletePayment(EmployeePayment payment)
    {
        if (!HasPermission("Workers_Payments", DemexClaims.Delete))
        {
            ToastService.Notify(new(ToastType.Warning, "Sin permiso", "No tienes permiso para eliminar pagos."));
            return;
        }

        var options = new ConfirmDialogOptions
        {
            YesButtonText = "Eliminar",
            YesButtonColor = ButtonColor.Danger,
            NoButtonText = "Cancelar",
            NoButtonColor = ButtonColor.Secondary
        };

        var confirm = await dialog.ShowAsync(
            title: "Eliminar pago",
            message1: $"¿Seguro que deseas eliminar el pago de {payment.Employee?.Name}?",
            message2: "Esta acción es irreversible.",
            confirmDialogOptions: options);

        if (confirm)
        {
            try
            {
                await paymentService.DeletePaymentAsync(payment.Id);
                await LoadPayments();
                ToastService.Notify(new(ToastType.Success, $"Pago eliminado correctamente."));
            }
            catch (Exception ex)
            {
                ToastService.Notify(new(ToastType.Danger, $"Error al eliminar el pago: {ex.Message}"));
            }
        }
    }

    private void EditPayment(EmployeePayment payment)
    {
        if (!HasPermission("Workers_Payments", DemexClaims.Edit))
        {
            ToastService.Notify(new(ToastType.Warning, "Sin permiso", "No tienes permiso para editar pagos."));
            return;
        }

        nav.NavigateTo($"/pagos/empleados/editar/{payment.Id}");
    }

    private async Task ViewPaymentDetails(EmployeePayment payment)
    {
        var parameters = new Dictionary<string, object> { { "PaymentId", payment.Id } };
        await modal.ShowAsync<ViewEmployeePayment>(
            title: $"Detalles del pago de {payment.Employee?.Name}",
            parameters: parameters);
    }
}

