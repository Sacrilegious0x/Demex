@page "/clientes"
@using LAFABRICA.Data.DB
@using LAFABRICA.Models.Interface;
@inject IClientService service;

<PageTitle>Clientes</PageTitle>

<Toasts class="p-3" AutoHide="true" Delay="4000" Placement="ToastsPlacement.TopRight" />
<ConfirmDialog @ref="dialog" />


	@if(clients == null)
	{
		<div class="d-flex justify-content-center">
			<Spinner Type="SpinnerType.Border"  Size="SpinnerSize.Large"/>
		</div>

	}else if (!clients.Any())
	{
		<div>
			<Alert Color="AlertColor.Primary"> 
				<Icon Name="IconName.InfoCircleFill" class="me-2"/>
			<strong>No hay clientes registrados </strong>
			</Alert>
		</div>
	}
	else
	{
		<div class="container mt-2">
		
			<div class="card">
				<div class="card-header ">
					<div class="d-flex justify-content-between align-items-center mt-3">
					<h3> <Icon Name="IconName.PersonFill"></Icon> Gestion de Clientes</h3>
						<button class="btn btn-primary"> <Icon Name="IconName.PlusLg"></Icon> Nuevo Cliente</button>
					</div>
					<div class="mt-3">
						<h6>Aqui la barra de busqueda y filtros</h6>
					</div>
										
				</div>
				<div class="card-body text-center">
					<div class="row">
					<div class="col-12 table-responsive" style=" max-height: 370px; overflow-y: auto;">
							<table class="table table-striped">
								<thead>
									<tr>
										<th>#</th>
										<th>Empresa</th>
										<th>Contacto</th>
										<th>Encargado</th>
										<th>Correo</th>
										<th>Ubicacion</th>
										<th>Zona</th>
										<th>Acciones</th>
									</tr>
								</thead>
								<tbody>

									@foreach (var clt in clients.Select((c, index) => new { c, index }))
									{
										<tr>
											<td>@(clt.index + 1)</td>
											<td>
											<div>@clt.c.Name</div>
												@if (clt.c.IsFrequent == 1)
												{
													<span class="badge bg-success mt-1" style="font-size: 0.8rem;">
														Cliente frecuente
													</span>
												}
											</td>
											<td>
											<div><Icon Name="IconName.Telephone"></Icon> @clt.c.PhoneNumber</div>
											<div class="text-black-50"><Icon Name="IconName.Telephone"></Icon> @clt.c.ManagerPhoneNumber</div>

												
											</td>
											<td><Icon Name="IconName.Person"></Icon> @clt.c.Manager</td>
											<td><Icon Name="IconName.EnvelopeAt"></Icon> @clt.c.Email</td>
											<td><Icon Name="IconName.Map"></Icon> @clt.c.Location</td>
											<td><Icon Name="IconName.PinMap"></Icon> @clt.c.SpecificLocation</td>
											<td>
												<button class="btn btn-show"> <Icon Class="icon-show" Name="IconName.Eye"></Icon> </button>
												<button Class="btn btn-edit"> <Icon Class="icon-edit" Name="IconName.PencilSquare"></Icon> </button>
												<button Class="btn btn-delete" @onclick="()=> DeleteClient(clt.c)"> 
													<Icon Name="IconName.Trash" Color="IconColor.Danger"></Icon>
												</button>
											</td>
										</tr>

									}
								</tbody>

							</table>

						</div>

					</div>
				</div>
				<div class="card-footer">
					<Icon Name="IconName.CircleFill" Color="IconColor.Success"></Icon>
					Clientes frecuentes: @quantityFrecuentClient(clients)
				</div>
				
			</div>
			
		</div>
		
	}

@code {
	[Inject] protected ToastService ToastService { get; set; } = default!;
	private List<Client>? clients;
	private ConfirmDialog dialog = default!;

	protected override async Task OnInitializedAsync()
	{
		await LoadClients();
	}
	private async Task LoadClients()
	{
		clients = (await service.GetAllClient()).ToList();
	}
	private int quantityFrecuentClient(List<Client> clents)
	{
		return clents.Count(c => c.IsFrequent == 1);
	}

	private async Task DeleteClient(Client cl)
	{
		var optons = new ConfirmDialogOptions
			{
				YesButtonText = "Eliminar",
				YesButtonColor = ButtonColor.Danger,
				NoButtonText = "Cancelar",
				NoButtonColor = ButtonColor.Secondary

			};
		var confirmation = await dialog.ShowAsync(
			title: "Eliminar cliente",
			message1: $"¿Estas seguro de eliminar a {cl.Name} ?",
			message2: "Esta accion es irreversible",
			confirmDialogOptions: optons);
		if (confirmation)
		{
			try
			{
				await service.Delete(cl.Id); //borra al cliente
				await LoadClients(); //recarga datos
				StateHasChanged(); //refresca
				ToastService.Notify(new(ToastType.Success, $"Se elimino correctamente a {cl.Name}"));

			}catch(Exception e)
			{
				ToastService.Notify(new(ToastType.Danger,
					$"Ocurrio un error al tratar de eliminar a {cl.Name}: {e.Message}."));
			}			
		}
	}

}
