@page "/Supplier/create"
@using LAFABRICA.Models
@using LAFABRICA.Services
@inject ISupplierService SupplierService
@inject NavigationManager NavigationManager

<div class="card shadow-sm h-100 d-flex flex-column">

    @* --- Header (Título) --- *@
    <div class="card-header p-4 border-bottom">
        <h1 class="h4 card-title text-gray-900 d-flex align-items-center">
            @* Icono de construcción (Bootstrap Icon) *@
            <i class="bi bi-building me-3" style="font-size: 1.5rem; color: #0f54a1;"></i>
            Registrar Nuevo Proveedor
        </h1>
    </div>

    @* --- Cuerpo del Formulario --- *@
    <div class="flex-grow-1 overflow-auto p-4">

        <EditForm Model="@supplier" OnValidSubmit="@HandleValidSubmit" class="mx-auto" style="max-width: 850px;">
            <DataAnnotationsValidator />

            <div class="row g-4">
                @* grid-cols-1 lg:grid-cols-2 gap-8 -> row g-4 (grid de Bootstrap) *@

                @* Columna 1: Información del Proveedor *@
                <div class="col-12 col-lg-6">
                    <div class="card h-100">
                        @* Reemplaza el div bg-gray-50 p-4 rounded-lg *@
                        <div class="card-body">
                            <h3 class="h5 card-title mb-4 d-flex align-items-center text-gray-900">
                                <i class="bi bi-person me-2" style="color: #0f54a1;"></i>
                                Información del Proveedor
                            </h3>

                            <div class="space-y-4">
                                @* space-y-4 -> divs con mb-3/mb-4 *@

                                @* Campo: Nombre *@
                                <div class="mb-3">
                                    <label for="name" class="form-label">Nombre de la empresa *</label>
                                    <InputText id="name" @bind-Value="supplier.Name" class="form-control" placeholder="Ej: Cerámica Nacional" required />
                                </div>

                                @* Campo: Correo Electrónico *@
                                <div class="mb-3">
                                    <label for="email" class="form-label">Correo electrónico</label>
                                    <InputText id="email" @bind-Value="supplier.Email" class="form-control" placeholder="correo@ejemplo.com" type="email" />
                                </div>

                                @* Campo: Teléfono *@
                                <div class="mb-3">
                                    <label for="phone" class="form-label">Teléfono *</label>
                                    <InputText id="phone" @bind-Value="supplier.Phone" class="form-control" placeholder="+506 8888-8888" required />
                                </div>

                            </div>
                        </div>
                    </div>
                </div>

                @* Columna 2: Ubicación y Detalles *@
                <div class="col-12 col-lg-6">
                    <div class="card h-100">
                        @* Reemplaza el div bg-gray-50 p-4 rounded-lg *@
                        <div class="card-body">
                            <h3 class="h5 card-title mb-4 d-flex align-items-center text-gray-900">
                                <i class="bi bi-geo-alt me-2" style="color: #0f54a1;"></i>
                                Ubicación y detalles
                            </h3>

                            <div class="space-y-4">

                                @* Campo: Dirección *@
                                <div class="mb-3">
                                    <label for="address" class="form-label">Dirección</label>
                                    <InputText id="address" @bind-Value="supplier.Address" class="form-control" placeholder="Dirección completa" />
                                </div>

                                @* Campo: Notas Adicionales (Textarea) *@
                                <div class="mb-3">
                                    <label for="notes" class="form-label">Notas adicionales</label>
                                    <InputTextArea id="notes" @bind-Value="supplier.Notes" class="form-control" placeholder="Información adicional..." rows="3" />
                                </div>

                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @* --- Nota (Alerta Azul de Bootstrap) --- *@
            <div class="alert alert-info alert-note my-4 p-4" role="alert">
                <div class="d-flex align-items-start">
                    <i class="bi bi-info-circle-fill me-3" style="font-size: 1.25rem;"></i>
                    <div>
                        <h4 class="alert-heading h6 m-0">Nota</h4>
                        <p class="mb-0 text-sm">
                            Los proveedores creados podrán asignarse a materiales más adelante.
                        </p>
                    </div>
                </div>
            </div>

            @* --- Botones de Acción (Footer) --- *@
            <div class="d-flex justify-content-end space-x-4 pt-4 border-top">
                <button type="button" class="btn btn-outline-secondary px-4" @onclick="HandleCancel">
                    Cancelar
                </button>
                <button type="submit" class="btn text-white px-4" style="background-color: #0f54a1;">
                    Crear Proveedor
                </button>
            </div>

        </EditForm>
    </div>
</div>


@* --- Bloque de Código C# --- *@
@code {
    // 1. Instancia del DTO que contendrá los datos del formulario
    private SupplierDto supplier = new SupplierDto();

    // 2. Método que se ejecuta al enviar el formulario (si es válido)
    private async Task HandleValidSubmit()
    {
        try
        {
            // Llama al nuevo método del servicio para agregar el proveedor
            var newSupplier = await SupplierService.AddSupplierAsync(supplier);

            // TODO: Agregar notificación de éxito
            Console.WriteLine($"Proveedor creado con ID: {newSupplier.Id}");

            // 3. Redirige a la lista de proveedores
            NavigationManager.NavigateTo("/Supplier");
        }
        catch (Exception ex)
        {
            // TODO: Manejo de error y mostrar mensaje al usuario
            Console.WriteLine($"Error al crear proveedor: {ex.Message}");
        }
    }

    // 4. Método para Cancelar y Redirigir
    private void HandleCancel()
    {
        NavigationManager.NavigateTo("/Supplier");
    }
}
