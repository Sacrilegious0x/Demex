@page "/inventario/crear"
@using BlazorBootstrap
@using LAFABRICA.Data.DB
@using LAFABRICA.Models.AuxiliarDTOS
@using LAFABRICA.Models.Interface
@using LAFABRICA.Models
@inject IMaterialService MaterialService
@inject ISupplierService SupplierService
@inject NavigationManager NavigationManager
@inject IWebHostEnvironment WebHostEnvironment

<PageTitle>Nuevo Material</PageTitle>
<Toasts class="p-3" AutoHide="true" Delay="4000" Placement="ToastsPlacement.TopRight" />

<div class="container mt-2">
	<div class="card">
		<div class="card-header">
			<div class="d-flex justify-content-between align-items-center mt-3">
				<h2>
					<Icon Name="IconName.Box" />
					<text>Registrar Nuevo Material</text>
				</h2>
				<a class="btn btn-outline-secondary" href="/inventario">
					<Icon Name="IconName.ArrowLeft"></Icon>
				</a>
			</div>
		</div>

		<div class="card-body">
			@if (Material_Supp_Inv_Dto != null && suppliers != null)
			{
				<EditForm Model="@Material_Supp_Inv_Dto" OnValidSubmit="@HandleValidSubmit" FormName="CreateMaterialForm" enctype="multipart/form-data">
					<DataAnnotationsValidator />

					<div class="d-flex justify-content-between">
						<div class="container-sm">
							<h3>Información del Material</h3>

							<div class="form-group row mb-3">
								<label class="col-md-5 col-form-label">Nombre del Material: <span class="text-danger">*</span></label>
								<div class="col-md-8">
									<TextInput class="border-1" @bind-Value="newMaterial.Name" placeholder="Ej: Tubo PVC 1/2 pulgada" required />
									<ValidationMessage For="@(() => newMaterial.Name)" />
								</div>
							</div>

							<div class="form-group row mb-3">
								<label class="col-md-5 col-form-label">Unidad de Medida: <span class="text-danger">*</span></label>
								<div class="col-md-8">
									<TextInput class="border-1" @bind-Value="newMaterial.Unit" placeholder="Ej: Metro (m), Kilogramo (kg)" required />
									<ValidationMessage For="@(() => newMaterial.Unit)" />
								</div>
							</div>

							<div class="form-group row mb-3">
								<label class="col-md-5 col-form-label">Precio de Compra: <span class="text-danger">*</span></label>
								<div class="col-md-8">
									<NumberInput class="border-1" @bind-Value="newMaterial.PricePurchase" type="number" step="0.01" placeholder="Ej: 5.50" required />
									<ValidationMessage For="@(() => newMaterial.PricePurchase)" />
								</div>
							</div>

							@* --- Fixesillo loco: De TextInput a InputFile --- *@
							<div class="form-group row mb-3">
								<label class="col-md-5 col-form-label">Foto (Opcional):</label>
								<div class="col-md-8">
									<InputFile class="form-control" OnChange="@HandleFileSelected" />
									@if (selectedImage != null)
									{
										<small class="text-muted">Seleccionado: @selectedImage.Name</small>
									}
								</div>
							</div>
		
						</div>

						<div class="container-sm">
							<h3>Suministro e Inventario Inicial</h3>

							<div class="form-group row mb-3">
								<label class="col-md-5 col-form-label">Proveedor Inicial: <span class="text-danger">*</span></label>
								<div class="col-md-8">
									<InputSelect class="form-select border-1" @bind-Value="Material_Supp_Inv_Dto.SupplierId">
										<option value="0" disabled>Seleccione un proveedor</option>
										@foreach (var s in suppliers)
										{
											<option value="@s.Id">@s.Name</option>
										}
									</InputSelect>
									<ValidationMessage For="@(() => Material_Supp_Inv_Dto.SupplierId)" />
								</div>
							</div>

							<div class="form-group row mb-3">
								<label class="col-md-5 col-form-label">Stock entrante: <span class="text-danger">*</span></label>
								<div class="col-md-8">
									<NumberInput class="border-1" @bind-Value="Material_Supp_Inv_Dto.Quantity" type="number" placeholder="Ej: 100" required />
									
								</div>
								<div>
									<p class="text-black-50">Cantidad que suele pedir.</p>
								</div>
							</div>
							<div class="form-group row mb-3">
								<label class="col-md-5 col-form-label">Stock Mínimo: <span class="text-danger">*</span></label>
								<div class="col-md-8">
									<NumberInput class="border-1" @bind-Value="Material_Supp_Inv_Dto.MinimumQuantity" placeholder="Ej: 50" required />
									<ValidationMessage For="@(() => Material_Supp_Inv_Dto.MinimumQuantity)" />
								</div>
							</div>
						</div>
					</div>

					<div class="alert alert-info mt-4" role="alert">
						<div class="d-flex align-items-start">
							<i class="bi bi-info-circle-fill me-2" style="font-size: 1.2rem;"></i>
							<div>
								<strong>Nota:</strong>
								El proveedor no puede ser modificado
							</div>
						</div>
					</div>

					@if (showAlert)
					{
						<div>
							<Alert Color="AlertColor.Warning">
								<Icon Name="IconName.ExclamationTriangleFill" />
								<strong>@alertMessage</strong>
							</Alert>
						</div>
					}

					<div class="d-flex justify-content-end mt-3">
						<button type="button" class="btn btn-outline-secondary me-2" @onclick="HandleCancel">
							Cancelar
						</button>
						<button type="submit" class="btn btn-primary">
							Guardar 
						</button>
					</div>
				</EditForm>
			}
			else
			{
				<div class="d-flex justify-content-center">
					<Spinner Type="SpinnerType.Border" Size="SpinnerSize.Large" />
				</div>
			}
		</div>
	</div>
</div>


@code {
	bool showAlert;
	string alertMessage;

	[Inject] protected ToastService ToastService { get; set; } = default!;

	// Instancia del DTO que contendrá los datos del formulario
	private MaterialSupplierInventoryDto Material_Supp_Inv_Dto = new MaterialSupplierInventoryDto();

	private Material newMaterial = new Material();

	// Lista de proveedores para el InputSelect
	private List<SupplierDto>? suppliers;

	private IBrowserFile? selectedImage;
	private long maxFileSize = 1024 * 1024 * 5; // Límite de 5MB

	protected override async Task OnInitializedAsync()
	{
		// Cargar la lista de proveedores para el dropdown
		suppliers = (await SupplierService.GetSuppliersAsync());
		// Inicializar SupplierId con 0 para forzar la validación de selección
		Material_Supp_Inv_Dto.SupplierId = 0;
	}

	// Método que se ejecuta al enviar el formulario
	private async Task HandleValidSubmit()
	{
		try
		{
			// 1. Subir el archivo ANTES de llamar al servicio
			string? uploadedPath = await UploadFileAsync();

			// Si la subida falló (y no fue porque no se seleccionó nada), detener.
			if (showAlert && selectedImage != null)
			{
				return;
			}

			// 2. Asignar la ruta (o null) al objeto material
			newMaterial.PhotoUrl = uploadedPath;

			newMaterial.IsActive = true;




			// La lógica del servicio se encargará de crear los 3 registros
			await MaterialService.CreateMaterial(newMaterial,Material_Supp_Inv_Dto.SupplierId,
				Material_Supp_Inv_Dto.Quantity,
				Material_Supp_Inv_Dto.MinimumQuantity);

			ToastService.Notify(new(ToastType.Success, $"Se agregó correctamente el material: {Material_Supp_Inv_Dto.MaterialName}"));

			await Task.Delay(1000);

			NavigationManager.NavigateTo("/inventario");
		}
		catch (InvalidOperationException ex)
		{
			showAlert = true;
			alertMessage = ex.Message;
		}
		catch (Exception ex)
		{
			ToastService.Notify(new(ToastType.Danger, $"Ocurrió un error al guardar el material."));
			Console.WriteLine($"Error al crear material: {ex.Message}");
		}
	}

	private void HandleFileSelected(InputFileChangeEventArgs e)
	{
		showAlert = false;
		alertMessage = "";

		if (e.File.Size > maxFileSize)
		{
			showAlert = true;
			alertMessage = $"El archivo es demasiado grande. El límite es {maxFileSize / 1024 / 1024} MB.";
			selectedImage = null;
			return;
		}

		selectedImage = e.File;
	}

	// --- NUEVO: Método para subir el archivo al servidor ---
	private async Task<string?> UploadFileAsync()
	{
		if (selectedImage == null)
		{
			return null; // No se seleccionó archivo
		}

		try
		{
			// 1. Definir la carpeta de destino relativa a wwwroot
			string relativeFolderPath = Path.Combine("images", "materials");
			// Obtener la ruta absoluta del servidor
			string absoluteFolderPath = Path.Combine(WebHostEnvironment.WebRootPath, relativeFolderPath);

			// 2. Asegurarse de que el directorio exista
			if (!Directory.Exists(absoluteFolderPath))
			{
				Directory.CreateDirectory(absoluteFolderPath);
			}

			// 3. Crear un nombre de archivo único para evitar colisiones
			string fileExtension = Path.GetExtension(selectedImage.Name);
			string uniqueFileName = $"{Guid.NewGuid()}{fileExtension}";
			string absoluteFilePath = Path.Combine(absoluteFolderPath, uniqueFileName);

			// 4. Guardar el archivo en el servidor
			await using (var fileStream = new FileStream(absoluteFilePath, FileMode.Create))
			{
				await selectedImage.OpenReadStream(maxFileSize).CopyToAsync(fileStream);
			}

			// 5. Devolver la RUTA RELATIVA que se guardará en la BD
			// Reemplazar '\\' por '/' para que sea una URL web válida
			string relativePath = Path.Combine(relativeFolderPath, uniqueFileName).Replace("\\", "/");

			return $"/{relativePath}"; // Ej: /images/materials/archivo-unico.jpg
		}
		catch (Exception ex)
		{
			Console.WriteLine($"Error al subir el archivo: {ex.Message}");
			showAlert = true;
			alertMessage = "Error al procesar la imagen.";
			return null;
		}
	}

	private void HandleCancel()
	{
		NavigationManager.NavigateTo("/inventario");
	}
}
