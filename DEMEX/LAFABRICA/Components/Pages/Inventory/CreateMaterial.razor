@page "/inventario/crear"
@using BlazorBootstrap
@using LAFABRICA.Models.AuxiliarDTOS
@using LAFABRICA.Models.Interface
@using LAFABRICA.Models
@inject IMaterialService MaterialService
@inject ISupplierService SupplierService
@inject NavigationManager NavigationManager

<PageTitle>Nuevo Material</PageTitle>
<Toasts class="p-3" AutoHide="true" Delay="4000" Placement="ToastsPlacement.TopRight" />

<div class="container mt-2">
	<div class="card">
		<div class="card-header">
			<div class="d-flex justify-content-between align-items-center mt-3">
				<h2>
					<Icon Name="IconName.Box" />
					<text>Registrar Nuevo Material</text>
				</h2>
				<a class="btn btn-outline-secondary" href="/materiales">
					<Icon Name="IconName.ArrowLeft"></Icon>
				</a>
			</div>
		</div>

		<div class="card-body">
			@if (model != null && suppliers != null)
			{
				<EditForm Model="@model" OnValidSubmit="@HandleValidSubmit">
					<DataAnnotationsValidator />

					<div class="d-flex justify-content-between">
						<div class="container-sm">
							<h3>Información del Material</h3>

							<div class="form-group row mb-3">
								<label class="col-md-5 col-form-label">Nombre del Material: <span class="text-danger">*</span></label>
								<div class="col-md-8">
									<TextInput class="border-1" @bind-Value="model.MaterialName" placeholder="Ej: Tubo PVC 1/2 pulgada" required />
									<ValidationMessage For="@(() => model.MaterialName)" />
								</div>
							</div>

							<div class="form-group row mb-3">
								<label class="col-md-5 col-form-label">Unidad de Medida: <span class="text-danger">*</span></label>
								<div class="col-md-8">
									<TextInput class="border-1" @bind-Value="model.Unit" placeholder="Ej: Metro (m), Kilogramo (kg)" required />
									<ValidationMessage For="@(() => model.Unit)" />
								</div>
							</div>

							<div class="form-group row mb-3">
								<label class="col-md-5 col-form-label">Precio de Compra: <span class="text-danger">*</span></label>
								<div class="col-md-8">
									<InputNumber class="border-1" @bind-Value="model.PricePurchase" type="number" step="0.01" placeholder="Ej: 5.50" required />
									<ValidationMessage For="@(() => model.PricePurchase)" />
								</div>
							</div>

							<div class="form-group row mb-3">
								<label class="col-md-5 col-form-label">URL de Foto (Opcional):</label>
								<div class="col-md-8">
									<TextInput class="border-1" @bind-Value="model.photoUrl" placeholder="https://..." />
									<ValidationMessage For="@(() => model.photoUrl)" />
								</div>
							</div>
						</div>

						<div class="container-sm">
							<h3>Suministro e Inventario Inicial</h3>

							<div class="form-group row mb-3">
								<label class="col-md-5 col-form-label">Proveedor Inicial: <span class="text-danger">*</span></label>
								<div class="col-md-8">
									<InputSelect class="form-select border-1" @bind-Value="model.SupplierId">
										<option value="0" disabled>Seleccione un proveedor</option>
										@foreach (var s in suppliers)
										{
											<option value="@s.Id">@s.Name</option>
										}
									</InputSelect>
									<ValidationMessage For="@(() => model.SupplierId)" />
								</div>
							</div>

							<div class="form-group row mb-3">
								<label class="col-md-5 col-form-label">Cant. Habitual de Suministro: <span class="text-danger">*</span></label>
								<div class="col-md-8">
									<InputNumber class="border-1" @bind-Value="model.Quantity" type="number" placeholder="Ej: 100" required />
									
								</div>
								<div>
									<p class="text-black-50">Cantidad que este proveedor suele vender o pedido mínimo.</p>
								</div>
							</div>
							<hr class="mt-4 mb-4" />

							<div class="form-group row mb-3">
								<label class="col-md-5 col-form-label">Stock Inicial: <span class="text-danger">*</span></label>
								<div class="col-md-8">
									<InputNumber class="border-1" @bind-Value="model.MinimumQuantity" type="number" placeholder="Ej: 500" required />
									<ValidationMessage For="@(() => model.MinimumQuantity)" />
								</div>
							</div>

							<div class="form-group row mb-3">
								<label class="col-md-5 col-form-label">Stock Mínimo: <span class="text-danger">*</span></label>
								<div class="col-md-8">
									<InputNumber class="border-1" @bind-Value="model.MinimumQuantity" type="number" placeholder="Ej: 50" required />
									<ValidationMessage For="@(() => model.MinimumQuantity)" />
								</div>
							</div>
						</div>
					</div>

					<div class="alert alert-info mt-4" role="alert">
						<div class="d-flex align-items-start">
							<i class="bi bi-info-circle-fill me-2" style="font-size: 1.2rem;"></i>
							<div>
								<strong>Nota:</strong>
								Se crearán el Material, su relación con el proveedor y el registro de Inventario inicial.
							</div>
						</div>
					</div>

					@if (showAlert)
					{
						<div>
							<Alert Color="AlertColor.Warning">
								<Icon Name="IconName.ExclamationTriangleFill" />
								<strong>@alertMessage</strong>
							</Alert>
						</div>
					}

					<div class="d-flex justify-content-end mt-3">
						<button type="button" class="btn btn-outline-secondary me-2" @onclick="HandleCancel">
							Cancelar
						</button>
						<button type="submit" class="btn btn-primary">
							Guardar Material
						</button>
					</div>
				</EditForm>
			}
			else
			{
				<div class="d-flex justify-content-center">
					<Spinner Type="SpinnerType.Border" Size="SpinnerSize.Large" />
				</div>
			}
		</div>
	</div>
</div>


@code {
	bool showAlert;
	string alertMessage;

	[Inject] protected ToastService ToastService { get; set; } = default!;

	// Instancia del DTO que contendrá los datos del formulario
	private MaterialSupplierInventoryDto model = new MaterialSupplierInventoryDto();

	// Lista de proveedores para el InputSelect
	private List<SupplierDto>? suppliers;

	protected override async Task OnInitializedAsync()
	{
		// Cargar la lista de proveedores para el dropdown
		suppliers = (await SupplierService.GetSuppliersAsync());
		// Inicializar SupplierId con 0 para forzar la validación de selección
		model.SupplierId = 0;
	}

	// Método que se ejecuta al enviar el formulario
	private async Task HandleValidSubmit()
	{
		try
		{
			// La lógica del servicio se encargará de crear los 3 registros
			//await MaterialService.CreateMaterialAndInventoryAsync(model);

			ToastService.Notify(new(ToastType.Success, $"Se agregó correctamente el material: {model.MaterialName}"));

			await Task.Delay(1000);

			NavigationManager.NavigateTo("/materiales");
		}
		catch (InvalidOperationException ex)
		{
			showAlert = true;
			alertMessage = ex.Message;
		}
		catch (Exception ex)
		{
			ToastService.Notify(new(ToastType.Danger, $"Ocurrió un error al guardar el material."));
			Console.WriteLine($"Error al crear material: {ex.Message}");
		}
	}

	private void HandleCancel()
	{
		NavigationManager.NavigateTo("/materiales");
	}
}
