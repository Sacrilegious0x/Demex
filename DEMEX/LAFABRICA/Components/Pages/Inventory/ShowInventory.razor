@page "/inventario"
@using LAFABRICA.Models.AuxiliarDTOS
@using LAFABRICA.Models.Interface
@using LAFABRICA.Services
@inject NavigationManager nav;
@inject IMaterialService materialService;

<PageTitle>Clientes</PageTitle>
<Toasts class="p-3" AutoHide="true" Delay="4000" Placement="ToastsPlacement.TopRight" />
<ConfirmDialog @ref="dialog" />

@if (materialDetails == null)
{
	<div class="d-flex justify-content-center">
		<Spinner Type="SpinnerType.Border" Size="SpinnerSize.Large" />
	</div>

}else if(!materialDetails.Any()){

    <div>
        <Alert Color="AlertColor.Primary" class="d-flex justify-content-between align-items-center">
            <div>
                <Icon Name="IconName.InfoCircleFill" class="me-2" />
                <strong>No hay clientes registrados </strong>
            </div>
            <a class="btn btn-outline-primary" href="/clientes/crear"><Icon Name="IconName.PlusLg" /> Nuevo Cliente</a>
        </Alert>
    </div>
   
}
else
{
    <div class="container mt-2">

        <div class="card">

           <div class="card-header">
                    <div class="d-flex justify-content-between align-items-center mt-3">
                            <h3> <Icon Name="IconName.Box"></Icon> Gestion de inventario</h3>
                            <a class="btn text-white" href="/inventario/crear" style="background-color: #0f54a1;"> <Icon Name="IconName.PlusLg"></Icon> Nuevo Cliente</a>
                    </div>

                <div class="d-flex justify-content-sm-start align-items-center gap-3 mt-3">

                    <div class="d-flex align-items-center border rounded px-2">
                        <Icon Name="IconName.Search" class="text-secondary me-2" />
                        <input type="text" class="form-control border-0" placeholder="Buscar Empresa..." style="box-shadow:none;" />
                    </div>

                </div>
             </div>


            <div class="card-body text-center">
                <div class="row">
                    <div class="col-12 table-responsive" style=" max-height: 370px; overflow-y: auto;">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Material</th>
                                    <th>Proveedor</th>
                                    <th>Cant. Suministro</th>
                                    <th>Stock Mínimo</th>
                                    <th>Precio Compra</th>
                                    <th>Foto</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var detail in materialDetails) // <--- Iterando sobre el VM
                                {
                                    <tr>
                                        <td>@detail.MaterialName (@detail.Unit)</td>
                                        <td>@detail.SupplierName</td>
                                        <td>@detail.Quantity</td>
                                        <td>@detail.MinimumQuantity</td>
                                        <td>@detail.PricePurchase</td>
                                        <td>@detail.photoUrl</td>
                                        <td>
                                            <button Class="btn btn-edit" @onclick="() => toEdit(detail.MaterialId)"> <Icon Class="icon-edit" Name="IconName.PencilSquare"></Icon> </button>
                                            <button Class="btn btn-delete" @onclick="() => toDelete(detail.MaterialId)">
                                                <Icon Name="IconName.Trash" Color="IconColor.Danger"></Icon>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>


        </div>

    </div>


  
}


@code {
    private List<MaterialSupplierInventoryDto>? materialDetails;
    private ConfirmDialog dialog = default!;

    

    protected override async Task OnInitializedAsync()
    {
        await LoadMaterials();
    }
    private async Task LoadMaterials()
    {
        materialDetails = (await materialService.GetMaterialDetails()).ToList();
    }

    private void toEdit(int MaterialId)
    {
        
    }

    private void toDelete(int MaterialId)
    {

    }


}
