@page "/proveedor/editar/{Id:int}"
@using BlazorBootstrap
@using LAFABRICA.Models
@using LAFABRICA.Models.Interface
@inject ISupplierService SupplierService
@inject NavigationManager NavigationManager


@*
     supplier es la que se precarga y se usa para el binding
     isBusy se usa para manejar el estado de carga y evitar broncas feas si el objeto es nulo
*@
<PageTitle>Editar Proveedor</PageTitle>
<Toasts class="p-3" AutoHide="true" Delay="4000" Placement="ToastsPlacement.TopRight" />
<ConfirmDialog @ref="dialog" />

@if (isBusy)
{
    <div class="text-center p-5">
        <p>Cargando información del proveedor...</p>
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Cargando...</span>
        </div>
    </div>
}
else if (supplier == null)
{
    <div class="alert alert-danger text-center m-4" role="alert">
        Proveedor con ID @Id no encontrado.
    </div>
}
else
{
    <div class="container mt-2">
        <div class="card">
            <div class="card-header">
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <h2>
                        <Icon Name="IconName.Building" />
                        <text>Editar Proveedor</text>
                    </h2>
                    <a class="btn btn-outline-secondary" href="/proveedor">
                        <Icon Name="IconName.ArrowLeft"></Icon>
                    </a>
                </div>
            </div>

            <div class="card-body">
                <EditForm Model="@supplier" OnValidSubmit="@ShowConfirmationAsync">
                    <DataAnnotationsValidator />

                    <div class="d-flex justify-content-between">
                        <!-- Columna izquierda -->
                        <div class="container-sm">
                            <h3>Información del proveedor</h3>

                            <div class="form-group row mb-3">
                                <label class="col-md-5 col-form-label">Nombre de la empresa: <span class="text-danger">*</span></label>
                                <div class="col-md-8">
                                    <InputText class="form-control border-1" id="name" @bind-Value="supplier.Name" placeholder="Ej: Cerámica Nacional" required />
                                    <ValidationMessage For="@(() => supplier.Name)" />
                                </div>
                            </div>

                            <div class="form-group row mb-3">
                                <label class="col-md-5 col-form-label">Correo electrónico:</label>
                                <div class="col-md-8">
                                    <InputText class="form-control border-1" id="email" @bind-Value="supplier.Email" type="email" placeholder="correo@ejemplo.com" />
                                    <ValidationMessage For="@(() => supplier.Email)" />
                                </div>
                            </div>

                            <div class="form-group row mb-3">
                                <label class="col-md-5 col-form-label">Teléfono: <span class="text-danger">*</span></label>
                                <div class="col-md-8">
                                    <InputText class="form-control border-1" id="phone" @bind-Value="supplier.Phone" placeholder="8888-8888" required />
                                    <ValidationMessage For="@(() => supplier.Phone)" />
                                </div>
                                <div>
                                    <p class="text-black-50">Formato admitido: xxxx-xxxx</p>
                                </div>
                            </div>
                        </div>

                        <!-- Columna derecha -->
                        <div class="container-sm">
                            <h3>Ubicación y detalles</h3>

                            <div class="form-group row mb-3">
                                <label class="col-md-5 col-form-label">Dirección:</label>
                                <div class="col-md-8">
                                    <InputText class="form-control border-1" id="address" @bind-Value="supplier.Address" placeholder="Dirección completa" />
                                    <ValidationMessage For="@(() => supplier.Address)" />
                                </div>
                            </div>

                            <div class="form-group row mb-3">
                                <label class="col-md-5 col-form-label">Notas adicionales:</label>
                                <div class="col-md-8">
                                    <InputTextArea id="notes" @bind-Value="supplier.Notes" class="form-control border-1" placeholder="Información adicional..." rows="3" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Nota informativa -->
                    <div class="alert alert-info mt-4" role="alert">
                        <div class="d-flex align-items-start">
                            <i class="bi bi-info-circle-fill me-2" style="font-size: 1.2rem;"></i>
                            <div>
                                <strong>Nota:</strong>
                                Los proveedores creados podrán asignarse a materiales más adelante.
                            </div>
                        </div>
                    </div>

                    <!-- Botones de acción -->
                    <div class="d-flex justify-content-end mt-3 border-top pt-3">
                        <button type="button" class="btn btn-outline-secondary me-2" @onclick="HandleCancel">
                            Cancelar
                        </button>
                        <button type="submit" class="btn btn-primary">
                            Guardar
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}



@code {
    // PParametro de la url
    [Parameter]
    public int Id { get; set; }

    [Inject] protected ToastService ToastService { get; set; } = default!;

    private SupplierDto? supplier;
    private bool isBusy = true;
    private ConfirmDialog dialog = default!;




    // Se llama automáticamente al inicializar el componente y cuando los parámetros (Id) cambian
    protected override async Task OnInitializedAsync()
    {
        // Lógica de carga
        supplier = await SupplierService.GetSupplierByIdAsync(Id);
        isBusy = false;
    }

    
    private void HandleCancel()
    {
        NavigationManager.NavigateTo("/proveedor");
    }

    

    private async Task ShowConfirmationAsync()
    {
        var options = new ConfirmDialogOptions
        {
            YesButtonText = "Confirmar",
            YesButtonColor = ButtonColor.Success,
            NoButtonText = "Cancelar",
            NoButtonColor = ButtonColor.Danger
        };

        var confirmation = await dialog.ShowAsync(
            title: "Deseas aplicar estos cambios?",
            message1: "Una vez editado se pierde la informacion anterior",
            confirmDialogOptions: options);

        if (confirmation)
        {
            if (supplier == null) return;

            Console.WriteLine(supplier.Notes);

            try
            {

                bool success = await SupplierService.UpdateSupplierAsync(supplier);

                if (success)
                {

                    ToastService.Notify(new(ToastType.Success, $"Proveedor '{supplier.Name}' editado con exito "));
                    Console.WriteLine($"Proveedor {supplier.Id} actualizado con éxito.");
                    await Task.Delay(1000);

                    NavigationManager.NavigateTo("/proveedor");
                }
                else
                {
                    ToastService.Notify(new(ToastType.Secondary, $"Proveedor '{supplier.Name}' no se realizaron cambios"));


                    await Task.Delay(1000);
                    Console.WriteLine("Error: El proveedor no pudo ser actualizado.");
                    NavigationManager.NavigateTo("/proveedor");
                }
            }
            catch (Exception ex)
            {
                ToastService.Notify(new(ToastType.Danger, $"Ocurrio un error inesperado al intentar actualizar al proveedor '{supplier.Name}' "));
                Console.WriteLine($"Error al actualizar proveedor desde el metodo en el razor: {ex.Message}");
            }
        }
        else
        {
            // Nada! xd
        }
    }
}
