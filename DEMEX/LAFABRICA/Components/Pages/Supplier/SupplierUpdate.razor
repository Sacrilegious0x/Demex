@page "/proveedor/editar/{Id:int}"
@attribute [Authorize]
@using BlazorBootstrap
@using LAFABRICA.Models
@using LAFABRICA.Models.AuxiliarDTOS
@using LAFABRICA.Models.Interface
@using LAFABRICA.Services
@using LAFABRICA.Services.Auth
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims

@inject NavigationManager NavigationManager
@inject ISupplierService SupplierService
@inject ToastService ToastService


<PageTitle>Editar Proveedor</PageTitle>
<Toasts class="p-3" AutoHide="true" Delay="4000" Placement="ToastsPlacement.TopRight" />
<ConfirmDialog @ref="dialog" />
@if (user == null)
{
    <div class="text-center p-5">
        <Spinner Color="SpinnerColor.Primary" />
        <p class="mt-2">Cargando autenticación...</p>
    </div>
}
else if (!HasPermission("Suppliers", DemexClaims.Edit))
{
    <div class="text-center mt-5">
        <i class="bi bi-shield-lock fs-1 text-warning"></i>
        <h4 class="mt-3">Acceso denegado</h4>
        <p>No tienes permiso para editar proveedores.</p>
    </div>
}
else if (isBusy)
{
    <div class="text-center p-5">
        <p>Cargando información del proveedor...</p>
        <div class="spinner-border text-primary">
            <span class="visually-hidden">Cargando...</span>
        </div>
    </div>
}
else if (supplier == null)
{
    <div class="alert alert-danger text-center m-4">
        Proveedor con ID @Id no encontrado.
    </div>
}
else
{
   
    <div class="container mt-2">
        <div class="card">
            <div class="card-header">
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <h2>
                        <Icon Name="IconName.Building" />
                        <text>Editar Proveedor</text>
                    </h2>
                    <a class="btn btn-outline-secondary" href="/proveedor">
                        <Icon Name="IconName.ArrowLeft"></Icon>
                    </a>
                </div>
            </div>

            <div class="card-body">
                <EditForm Model="@supplier" OnValidSubmit="@ShowConfirmationAsync">
                    <DataAnnotationsValidator />

                    <div class="d-flex justify-content-between">
                        <div class="container-sm">
                            <h3>Información del proveedor</h3>

                            <div class="form-group row mb-3">
                                <label class="col-md-5 col-form-label">Nombre de la empresa: *</label>
                                <div class="col-md-8">
                                    <InputText class="form-control border-1" id="name" @bind-Value="supplier.Name" required />
                                    <ValidationMessage For="@(() => supplier.Name)" />
                                </div>
                            </div>

                            <div class="form-group row mb-3">
                                <label class="col-md-5 col-form-label">Correo electrónico:</label>
                                <div class="col-md-8">
                                    <InputText class="form-control border-1" id="email" @bind-Value="supplier.Email" type="email" />
                                    <ValidationMessage For="@(() => supplier.Email)" />
                                </div>
                            </div>

                            <div class="form-group row mb-3">
                                <label class="col-md-5 col-form-label">Teléfono: *</label>
                                <div class="col-md-8">
                                    <InputText class="form-control border-1" id="phone" @bind-Value="supplier.Phone" required />
                                    <ValidationMessage For="@(() => supplier.Phone)" />
                                </div>
                            </div>
                        </div>

                        <div class="container-sm">
                            <h3>Ubicación y detalles</h3>
                            <div class="form-group row mb-3">
                                <label class="col-md-5 col-form-label">Dirección:</label>
                                <div class="col-md-8">
                                    <InputText class="form-control border-1" @bind-Value="supplier.Address" />
                                </div>
                            </div>

                            <div class="form-group row mb-3">
                                <label class="col-md-5 col-form-label">Notas adicionales:</label>
                                <div class="col-md-8">
                                    <InputTextArea @bind-Value="supplier.Notes" class="form-control border-1" rows="3" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end mt-3 border-top pt-3">
                        <button type="button" class="btn btn-outline-secondary me-2" @onclick="HandleCancel">
                            Cancelar
                        </button>
                        <button type="submit" class="btn btn-primary">
                            Guardar
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private SupplierDto? supplier;
    private bool isBusy = true;
    private ConfirmDialog dialog = default!;
    [CascadingParameter] 
    private Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;
    private ClaimsPrincipal? user;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthenticationStateTask!;
        user = auth.User;

        supplier = await SupplierService.GetSupplierByIdAsync(Id);
        isBusy = false;
    }

    private bool HasPermission(string module, string action)
        => user?.HasClaim($"can_{module.ToUpper()}_{action}", "True") ?? false;

    private void HandleCancel()
    {
        NavigationManager.NavigateTo("/proveedor");
    }

    private async Task ShowConfirmationAsync()
    {
        if (!HasPermission("Suppliers", DemexClaims.Edit))
        {
            ToastService.Notify(new(ToastType.Warning, "No tienes permiso para editar proveedores."));
            return;
        }

        var confirm = await dialog.ShowAsync(
            "¿Seguro?",
            "Una vez editado se pierde la información anterior"
        );

        if (confirm)
        {
            await SupplierService.UpdateSupplierAsync(supplier!);
            ToastService.Notify(new(ToastType.Success, $"Proveedor '{supplier!.Name}' editado con éxito"));
            await Task.Delay(1000);
            NavigationManager.NavigateTo("/proveedor");
        }
    }
}
