@page "/proveedor/editar/{Id:int}"
@using BlazorBootstrap
@using LAFABRICA.Models
@using LAFABRICA.Models.Interface
@inject ISupplierService SupplierService
@inject NavigationManager NavigationManager


@*
     supplier es la que se precarga y se usa para el binding
     isBusy se usa para manejar el estado de carga y evitar broncas feas si el objeto es nulo
*@
<Toasts Class="p-3" AutoHide="true" Delay="4000" Placement="ToastsPlacement.TopRight"></Toasts>

<ConfirmDialog @ref="dialog" />

@if (isBusy)
{
    <div class="text-center p-5">
        <p>Cargando información del proveedor...</p>
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Cargando...</span>
        </div>
    </div>
}
else if (supplier == null)
{
    <div class="alert alert-danger text-center m-4" role="alert">
        Proveedor con ID @Id no encontrado.
    </div>
}
else
{
    <div class="card shadow-sm h-100 d-flex flex-column">

        @*Header   *@
        <div class="card-header p-4 border-bottom">
            <div class="d-flex justify-content-between align-items-center mt-3">
                <h1 class="h4 card-title text-gray-900 d-flex align-items-center">
                    <i class="bi bi-building me-3" style="font-size: 1.5rem; color: #0f54a1;"></i>
                    Editar Proveedor: @supplier.Name
                </h1>
                <a class="btn btn-outline-secondary" href="/proveedor"><Icon Name="IconName.ArrowLeft"></Icon></a>
            </div>
           
        </div>

        @*  Formulario *@
        <div class="flex-grow-1 overflow-auto p-4">

            <EditForm Model="@supplier" OnValidSubmit="@ShowConfirmationAsync" class="mx-auto" style="max-width: 850px;">
                <DataAnnotationsValidator />
                <div class="row g-4">
                    @* Columna 1: Información del Proveedor *@
                    <div class="col-12 col-lg-6">
                        <div class="card h-100">
                            <div class="card-body">
                                <h3 class="h5 card-title mb-4 d-flex align-items-center text-gray-900">
                                    <i class="bi bi-person me-2" style="color: #0f54a1;"></i>
                                    Información del Proveedor
                                </h3>

                                <div class="space-y-4">

                                    @* Campo: Nombre *@
                                    <div class="mb-3">
                                        <label for="name" class="form-label">Nombre de la empresa *</label>
                                        <InputText id="name" @bind-Value="supplier.Name" class="form-control" placeholder="Ej: Cerámica Nacional" required />
                                        <ValidationMessage For="@(() => supplier.Name)" />
                                    </div>

                                    @* Campo: Correo Electrónico *@
                                    <div class="mb-3">
                                        <label for="email" class="form-label">Correo electrónico</label>
                                        <InputText id="email" @bind-Value="supplier.Email" class="form-control" placeholder="correo@ejemplo.com" type="email" />
                                        <ValidationMessage For="@(() => supplier.Email)" />
                                    </div>

                                    @* Campo: Teléfono *@
                                    <div class="mb-3">
                                        <label for="phone" class="form-label">Teléfono *</label>
                                        <InputText id="phone" @bind-Value="supplier.Phone" class="form-control" placeholder="+506 8888-8888" required />
                                        <ValidationMessage For="@(() => supplier.Phone)" />
                                        <div>
                                            <p class="text-black-50">Formato admitido: xxxx-xxxx</p>
                                        </div>
                                    </div>



                                </div>
                            </div>
                        </div>
                    </div>

                    @* Columna 2: Ubicación y Detalles *@
                    <div class="col-12 col-lg-6">
                        <div class="card h-100">
                            <div class="card-body">
                                <h3 class="h5 card-title mb-4 d-flex align-items-center text-gray-900">
                                    <i class="bi bi-geo-alt me-2" style="color: #0f54a1;"></i>
                                    Ubicación y detalles
                                </h3>

                                <div class="space-y-4">

                                    @* Campo: Dirección *@
                                    <div class="mb-3">
                                        <label for="address" class="form-label">Dirección</label>
                                        <InputText id="address" @bind-Value="supplier.Address" class="form-control" placeholder="Dirección completa" />
                                        <ValidationMessage For="@(() => supplier.Address)" />
                                    </div>

                                    @* Campo: Notas Adicionales  *@
                                    <div class="mb-3">
                                        <label for="notes" class="form-label">Notas adicionales</label>
                                        <InputTextArea id="notes" @bind-Value="supplier.Notes" class="form-control" placeholder="Información adicional..." rows="3" />
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                @*  NotaAlerta Azul de Bootstrap*@
                <div class="alert alert-info alert-note my-4 p-4" role="alert">
                    <div class="d-flex align-items-start">
                        <i class="bi bi-info-circle-fill me-3" style="font-size: 1.25rem;"></i>
                        <div>
                            <h4 class="alert-heading h6 m-0">Nota</h4>
                            <p class="mb-0 text-sm">
                                Los proveedores creados podrán asignarse a materiales más adelante.
                            </p>
                        </div>
                    </div>
                </div>

                @* --- Botones de Acción (Footer) --- *@
                <div class="d-flex justify-content-end space-x-4 pt-4 border-top">

                    <button type="button" class="btn btn-outline-secondary px-4 m-1" @onclick="HandleCancel">
                        Cancelar
                    </button>
                    <button type="submit" class="btn text-white px-4 m-1" style="background-color: #0f54a1;">
                        Guardar
                    </button>
                </div>

            </EditForm>
        </div>
    </div>
}


@code {
    // PParametro de la url
    [Parameter]
    public int Id { get; set; }

    [Inject] protected ToastService ToastService { get; set; } = default!;

    private SupplierDto? supplier;
    private bool isBusy = true;
    private ConfirmDialog dialog = default!;




    // Se llama automáticamente al inicializar el componente y cuando los parámetros (Id) cambian
    protected override async Task OnInitializedAsync()
    {
        // Lógica de carga
        supplier = await SupplierService.GetSupplierByIdAsync(Id);
        isBusy = false;
    }

    
    private void HandleCancel()
    {
        NavigationManager.NavigateTo("/proveedor");
    }

    

    private async Task ShowConfirmationAsync()
    {
        var options = new ConfirmDialogOptions
        {
            YesButtonText = "Confirmar",
            YesButtonColor = ButtonColor.Success,
            NoButtonText = "Cancelar",
            NoButtonColor = ButtonColor.Danger
        };

        var confirmation = await dialog.ShowAsync(
            title: "Deseas aplicar estos cambios?",
            message1: "Una vez editado se pierde la informacion anterior",
            confirmDialogOptions: options);

        if (confirmation)
        {
            if (supplier == null) return;

            Console.WriteLine(supplier.Notes);

            try
            {

                bool success = await SupplierService.UpdateSupplierAsync(supplier);

                if (success)
                {

                    ToastService.Notify(new(ToastType.Success, $"Proveedor '{supplier.Name}' editado con exito "));
                    Console.WriteLine($"Proveedor {supplier.Id} actualizado con éxito.");
                    await Task.Delay(1000);

                    NavigationManager.NavigateTo("/proveedor");
                }
                else
                {
                    ToastService.Notify(new(ToastType.Secondary, $"Proveedor '{supplier.Name}' no se realizaron cambios"));


                    await Task.Delay(1000);
                    Console.WriteLine("Error: El proveedor no pudo ser actualizado.");
                    NavigationManager.NavigateTo("/proveedor");
                }
            }
            catch (Exception ex)
            {
                ToastService.Notify(new(ToastType.Danger, $"Ocurrio un error inesperado al intentar actualizar al proveedor '{supplier.Name}' "));
                Console.WriteLine($"Error al actualizar proveedor desde el metodo en el razor: {ex.Message}");
            }
        }
        else
        {
            // Nada! xd
        }
    }
}
