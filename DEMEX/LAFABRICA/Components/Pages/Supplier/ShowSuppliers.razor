@page "/proveedor"
@attribute [Authorize]
@using BlazorBootstrap
@using LAFABRICA.Data.DB
@using LAFABRICA.Models
@using LAFABRICA.Models.AuxiliarDTOS
@using LAFABRICA.Models.Interface
@using LAFABRICA.Services.Auth
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims

@inject ISupplierService SupplierService
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthStateProvider
@inject ToastService toastService

<Toasts Class="p-3" AutoHide="true" Delay="4000" Placement="ToastsPlacement.TopRight"></Toasts>
<ConfirmDialog @ref="dialog" />

@if (user == null)
{
    <div class="d-flex justify-content-center">
        <Spinner Type="SpinnerType.Border" Size="SpinnerSize.Large" />
    </div>
}
else if (!HasPermission("Suppliers", DemexClaims.View))
{
    <div class="text-center mt-5">
        <i class="bi bi-shield-lock fs-1 text-warning"></i>
        <h4 class="mt-3">Acceso denegado</h4>
        <p>No tienes permiso para ver proveedores.</p>
    </div>
}
else if (suppliers == null)
{
    <div class="d-flex justify-content-center">
        <Spinner Type="SpinnerType.Border" Size="SpinnerSize.Large" />
    </div>
}
else if (!suppliers.Any())
{
    <div>
        <Alert Color="AlertColor.Primary" class="d-flex justify-content-between align-items-center">
            <div>
                <Icon Name="IconName.InfoCircleFill" class="me-2" />
                <strong>No hay proveedores registrados</strong>
            </div>

            @if (HasPermission("Suppliers", DemexClaims.Create))
            {
                <a class="btn btn-outline-primary" href="/proveedor/crear">
                    <Icon Name="IconName.PlusLg" /> Nuevo Proveedor
                </a>
            }
        </Alert>
    </div>
}
else
{
    <div class="card shadow-sm h-100 d-flex flex-column">
        <div class="card-header p-4 border-bottom">
            <div class="d-flex justify-content-between align-items-center mt-3">

                <h2> <Icon Name="IconName.Truck" /> Gestión de Proveedores</h2>

                @if (HasPermission("Suppliers", DemexClaims.Create))
                {
                    <button class="btn text-white" style="background-color: #0f54a1;" @onclick="NavigateToCreate">
                        <i class="bi bi-plus-lg me-2"></i> Nuevo Proveedor
                    </button>
                }
            </div>

            <div class="d-flex align-items-center mt3">
                <div class="input-group" style="max-width:480px;">
                    <span class="input-group-text bg-white border-end-0">
                        <i class="bi bi-search text-gray-400"></i>
                    </span>
                    <input type="text"
                           class="form-control border-start-0"
                           placeholder="Buscar proveedores..."
                           value="@searchTerm"
                           @oninput="HandleSearch" />
                </div>
            </div>
        </div>

        <div class="table-responsive flex-grow-1 overflow-auto" style="max-height: 370px;">
            <table class="table table-hover text-center">
                <thead >
                    <tr>
                        <th>#</th>
                        <th>Nombre</th>
                        <th>Teléfono</th>
                        <th>Correo</th>
                        <th>Notas</th>
                        <th>Dirección</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var supplier in FilteredSuppliers.Select((c, index) => new { c, index }))
                    {
                        <tr>
                            <td>@(supplier.index + 1)</td>
                            <td>@supplier.c.Name</td>
                            <td>@supplier.c.Phone</td>
                            <td>@supplier.c.Email</td>
                            <td class="max-w-xs text-truncate">@supplier.c.Notes</td>
                            <td>@supplier.c.Address</td>
                            <td>
                                <div class="d-flex justify-content-center space-x-2">

                                    @if (HasPermission("Suppliers", DemexClaims.Edit))
                                    {
                                        <button class="btn btn-edit text-primary"
                                                @onclick="() => HandleEdit(supplier.c)">
                                            <Icon Class="icon-edit" Name="IconName.PencilSquare"></Icon>
                                        </button>
                                    }

                                    @if (HasPermission("Suppliers", DemexClaims.Delete))
                                    {
                                        <button class="btn btn-delete text-danger"
                                                @onclick="() => ShowDeleteConfirmationAsync(supplier.c.Id)">
                                            <Icon Name="IconName.Trash" Color="IconColor.Danger"></Icon>
                                        </button>
                                    }

                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>


            <div class="card-footer">
                <Icon Name="IconName.Truck" /> Total de proveedores activos: @FilteredSuppliers.Count()
            </div>
        </div>
    </div>
}

@code {

    [CascadingParameter] private Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;
    private ClaimsPrincipal? user;

    private List<SupplierDto>? suppliers;
    private string searchTerm = string.Empty;

    private List<SupplierDto> FilteredSuppliers =>
        suppliers?.Where(s =>
            s.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
            s.Phone.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
            s.Email.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
            s.Address.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)
        ).ToList() ?? new();

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthenticationStateTask;
        user = auth.User;

        if (HasPermission("Suppliers", DemexClaims.View))
            suppliers = await SupplierService.GetSuppliersAsync();
    }

    private bool HasPermission(string module, string action)
        => user?.HasClaim($"can_{module.ToUpper()}_{action}", "True") ?? false;

    private void NavigateToCreate()
    {
        if (!HasPermission("Suppliers", DemexClaims.Create)) return;
        NavigationManager.NavigateTo("/proveedor/crear");
    }

    private void HandleEdit(SupplierDto supplier)
    {
        if (!HasPermission("Suppliers", DemexClaims.Edit)) return;
        NavigationManager.NavigateTo($"/proveedor/editar/{supplier.Id}");
    }

    private void HandleSearch(ChangeEventArgs e)
        => searchTerm = e.Value?.ToString() ?? "";

    private ConfirmDialog dialog = default!;

    private async Task ShowDeleteConfirmationAsync(int id)
    {
        if (!HasPermission("Suppliers", DemexClaims.Delete))
        {
            toastService.Notify(new(ToastType.Warning, "No tienes permiso para eliminar proveedores."));
            return;
        }

        var confirm = await dialog.ShowAsync(
            title: "Eliminar proveedor",
            message1: "¿Seguro que deseas eliminar este proveedor?",
            message2: "Esta acción es irreversible.",
            confirmDialogOptions: new ConfirmDialogOptions
            {
                YesButtonText = "Eliminar",
                YesButtonColor = ButtonColor.Danger,
                NoButtonText = "Cancelar",
                NoButtonColor = ButtonColor.Secondary
            });

        if (confirm)
        {
            await SupplierService.DeleteSupplierAsync(id);
            toastService.Notify(new(ToastType.Success, "Proveedor eliminado correctamente."));
            NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true);
        }
    }
}
