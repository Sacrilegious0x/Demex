@page "/proveedor/crear"
@using BlazorBootstrap
@using LAFABRICA.Models
@using LAFABRICA.Models.Interface
@using LAFABRICA.Services
@inject ISupplierService SupplierService
@inject NavigationManager NavigationManager
<PageTitle>Nuevo Proveedor</PageTitle>
<Toasts class="p-3" AutoHide="true" Delay="4000" Placement="ToastsPlacement.TopRight" />


<div class="container mt-2">
	<div class="card">
		<div class="card-header">
			<div class="d-flex justify-content-between align-items-center mt-3">
				<h2>
					<Icon Name="IconName.Building" />
					<text>Registrar nuevo proveedor</text>
				</h2>
				<a class="btn btn-outline-secondary" href="/proveedor">
					<Icon Name="IconName.ArrowLeft"></Icon>
				</a>
			</div>
		</div>

		<div class="card-body">
			@if (supplier != null)
			{
				<EditForm Model="@supplier" OnValidSubmit="@HandleValidSubmit">
					<DataAnnotationsValidator />

					<div class="d-flex justify-content-between">
						<!-- Columna izquierda -->
						<div class="container-sm">
							<h3>Información del proveedor</h3>

							<div class="form-group row mb-3">
								<label class="col-md-5 col-form-label">Nombre de la empresa: <span class="text-danger">*</span></label>
								<div class="col-md-8">
									<TextInput class="border-1" id="name" @bind-Value="supplier.Name" placeholder="Ej: Cerámica Nacional" required />
									<ValidationMessage For="@(() => supplier.Name)" />
								</div>
							</div>

							<div class="form-group row mb-3">
								<label class="col-md-5 col-form-label">Correo electrónico:</label>
								<div class="col-md-8">
									<TextInput class="border-1" id="email" @bind-Value="supplier.Email" type="email" placeholder="correo@ejemplo.com" />
									<ValidationMessage For="@(() => supplier.Email)" />
								</div>
							</div>

							<div class="form-group row mb-3">
								<label class="col-md-5 col-form-label">Teléfono: <span class="text-danger">*</span></label>
								<div class="col-md-8">
									<TextInput class="border-1" id="phone" @bind-Value="supplier.Phone" placeholder="8888-8888" required />
									<ValidationMessage For="@(() => supplier.Phone)" />
								</div>
								<div>
									<p class="text-black-50">Formato admitido: xxxx-xxxx</p>
								</div>
							</div>
						</div>

						<!-- Columna derecha -->
						<div class="container-sm">
							<h3>Ubicación y detalles</h3>

							<div class="form-group row mb-3">
								<label class="col-md-5 col-form-label">Dirección:</label>
								<div class="col-md-8">
									<TextInput class="border-1" id="address" @bind-Value="supplier.Address" placeholder="Dirección completa" />
									<ValidationMessage For="@(() => supplier.Address)" />
								</div>
							</div>

							<div class="form-group row mb-3">
								<label class="col-md-5 col-form-label">Notas adicionales:</label>
								<div class="col-md-8">
									<InputTextArea id="notes" @bind-Value="supplier.Notes" class="form-control border-1" placeholder="Información adicional..." rows="3" />
								</div>
							</div>
						</div>
					</div>

					<!-- Alerta informativa -->
					<div class="alert alert-info mt-4" role="alert">
						<div class="d-flex align-items-start">
							<i class="bi bi-info-circle-fill me-2" style="font-size: 1.2rem;"></i>
							<div>
								<strong>Nota:</strong>
								Los proveedores creados podrán asignarse a materiales más adelante.
							</div>
						</div>
					</div>

					@if (showAlert)
					{
						<div>
							<Alert Color="AlertColor.Warning">
								<Icon Name="IconName.ExclamationTriangleFill" />
								<strong>@alertMessage</strong>
							</Alert>
						</div>
					}

					<!-- Botones de acción -->
					<div class="d-flex justify-content-end mt-3">
						<button type="button" class="btn btn-outline-secondary me-2" @onclick="HandleCancel">
							Cancelar
						</button>
						<button type="submit" class="btn btn-primary">
							Guardar
						</button>
					</div>
				</EditForm>
			}
			else
			{
				<div class="d-flex justify-content-center">
					<Spinner Type="SpinnerType.Border" Size="SpinnerSize.Large" />
				</div>
			}
		</div>
	</div>
</div>


@code {

    bool showAlert;
    string alertMessage;

    [Inject] protected ToastService ToastService { get; set; }

    //  Instancia del DTO que contendrá los datos del formulario
    private SupplierDto supplier = new SupplierDto();

    



    // Método que se ejecuta al enviar el formulario solo es valido ojito :v
    private async Task HandleValidSubmit()
    {
        supplier.IsActive = true;

        try
        {


            var newSupplier = await SupplierService.AddSupplierAsync(supplier);

            ToastService.Notify(new(ToastType.Success, $"Se agrego correctamente a {supplier.Name}"));

            Console.WriteLine($"Proveedor creado con ID: {newSupplier.Id}");

            await Task.Delay(1000);

            NavigationManager.NavigateTo("/proveedor");
        }
        catch (InvalidOperationException ex)
        {
            showAlert = true;
            alertMessage = ex.Message;
        }
        catch (Exception ex)
        {
            ToastService.Notify(new(ToastType.Danger, $"Se agrego correctamente a {supplier.Name}"));
            await Task.Delay(1000);
            Console.WriteLine($"Error al crear proveedor: {ex.Message}");
        }
    }

    private void HandleCancel()
    {
        NavigationManager.NavigateTo("/proveedor");
    }
}
