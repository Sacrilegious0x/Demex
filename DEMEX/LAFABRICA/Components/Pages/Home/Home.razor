@page "/"
@using LAFABRICA.Data.DB
@using LAFABRICA.Models.Interface
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Authorization
@inject IProductService productService
@inject IClientService clientService
@inject IOrderService orderService
@inject IClientPaymentService paymentService
@inject AppDbContext _context


<style>
    .dashboard-card-link {
        text-decoration: none;
    }

            .dashboard-card-link .card:hover {
                transform: translateY(-5px);
                box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
                transition: all 0.2s ease-in-out;
            }

    .disabled-card {
        opacity: 0.65;
        pointer-events: none;
    }

            .disabled-card .fw-bold,
            .disabled-card .h5,
            .disabled-card .bi {
                color: #6c757d !important;
            }
    </style>

<PageTitle>Inicio - Dashboard</PageTitle>
<AuthorizeView>
    <Authorized>
        <div class="container-fluid">
            <div class="row mb-4">
                <div class="col">
                    <h3 id="welcomeUser">Bienvenido al Sistema de Gestión DEMEX</h3>
                    <p class="text-muted">Resumen general de la actividad del negocio.</p>
                   
                </div>
            </div>
        </div>

        @if (isLoading)
        {
            <div class="text-center">
                <Spinner Color="SpinnerColor.Primary" />
                <p class="mt-2">Cargando datos del dashboard...</p>
            </div>
        }
        else
        {
            <div class="row">
                @* Tarjeta Órdenes Activas *@
                <div class="col-xl-3 col-md-6 mb-4">
                    <a href="/ordenes" class="dashboard-card-link">
                        <div class="card shadow h-100 py-2" style="border-left: 5px solid #0f54a1;">
                            <div class="card-body">
                                <div class="row no-gutters align-items-center">
                                    <div class="col mr-2">
                                        <div class="text-xs fw-bold text-uppercase mb-1">Órdenes Activas</div>
                                        <div class="h5 mb-0 fw-bold text-gray-800">@activeOrdersCount</div>
                                    </div>
                                    <div class="col-auto">
                                        <i class="bi bi-cart-check-fill fs-2"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>

                @* Tarjeta Gestión de Pagos *@
                <div class="col-xl-3 col-md-6 mb-4">
                    <a href="/pagos" class="dashboard-card-link">
                        <div class="card shadow h-100 py-2" style="border-left: 5px solid #893914;">
                            <div class="card-body">
                                <div class="row no-gutters align-items-center">
                                    <div class="col mr-2">
                                        <div class="text-xs fw-bold text-uppercase mb-1" style="color:#893914;">Gestión de Pagos</div>
                                        <div class="h5 mb-0 fw-bold text-gray-800">@totalPaymentsCount</div>
                                    </div>
                                    <div class="col-auto">
                                        <i class="bi bi-credit-card-fill fs-2 text-black-50 opacity-25"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>

                @* Tarjeta Productos *@
                <div class="col-xl-3 col-md-6 mb-4">
                    <a href="/productos" class="dashboard-card-link">
                        <div class="card shadow h-100 py-2" style="border-left: 5px solid #189182;">
                            <div class="card-body">
                                <div class="row no-gutters align-items-center">
                                    <div class="col mr-2">
                                        <div class="text-xs fw-bold text-uppercase mb-1" style="color: #189182;">Productos en Catálogo</div>
                                        <div class="h5 mb-0 fw-bold text-gray-800">@activeProductsCount</div>
                                    </div>
                                    <div class="col-auto">
                                        <i class="bi bi-box-seam-fill fs-2 text-black-50 opacity-25"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>

                @* Tarjeta Alertas Inventario *@
                <div class="col-xl-3 col-md-6 mb-4">
                    <a href="/reportes" class="dashboard-card-link">
                        <div class="card shadow h-100 py-2" style="border-left: 5px solid #ebcf4f;">
                            <div class="card-body">
                                <div class="row no-gutters align-items-center">
                                    <div class="col mr-2">
                                        <div class="text-xs fw-bold text-uppercase mb-1" style="color: #ebcf4f;">Alertas de Inventario</div>
                                        <div class="h5 mb-0 fw-bold text-gray-800">@inventoryAlertCount</div>
                                    </div>
                                    <div class="col-auto">
                                        <i class="bi bi-exclamation-triangle-fill fs-2 text-warning opacity-75"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            </div>
        }

    </Authorized>

    <NotAuthorized>
        <div class="text-center mt-5">
            <i class="bi bi-lock-fill text-secondary" style="font-size: 3rem;"></i>
            <h4 class="mt-3">Acceso restringido</h4>
            <p>Debes iniciar sesión para ver el contenido del sistema.</p>
            <a id="goToLoginBtn" href="/login" class="btn text-white" style="background-color: #0f54a1;">Ir al inicio de sesión</a>
        </div>
    </NotAuthorized>
</AuthorizeView>


@code {
    private bool isLoading = true;
    private int activeOrdersCount = 0;
    private int activeProductsCount = 0;
    private int totalPaymentsCount = 0;
    private int inventoryAlertCount = 0; // Se mantiene la variable

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Carga secuencial 
            var allProducts = await productService.GetAllProducts();
            var allOrders = await orderService.GetAllOrders();
            var allPayments = await paymentService.GetAllPayments();

            // Cálculo de Alertas de Inventario 
           
            inventoryAlertCount = await _context.Materials
                // Filtrar solo materiales activos (IsActive = 1 o true)
                .Where(m => m.IsActive == true || m.IsActive == true)

                //  Unir con Inventario y MaterialSupplier
                .Join(_context.Inventories,
                      m => m.Id,
                      i => i.MaterialId,
                      (m, i) => new { Material = m, Inventory = i })

                //  Usamos SelectMany para obtener todas las posibles relaciones MaterialSupplier
                .SelectMany(
                    anon => _context.MaterialSuppliers
                                    .Where(ms => ms.MaterialId == anon.Material.Id),
                    (anon, ms) => new { anon.Material, anon.Inventory, MaterialSupplier = ms }
                )

                //  Aplicar la condición de Alerta: Stock Actual <= Cantidad Mínima
                // Se verifica que Quantity tenga un valor antes de comparar.
                .CountAsync(dto => dto.MaterialSupplier.Quantity.HasValue && dto.MaterialSupplier.Quantity <= dto.Inventory.MinimunQuantity);

            // Contar después de cargar todo
            activeProductsCount = allProducts.Count();
            activeOrdersCount = allOrders.Count(o => o.State != "Finalizada");
            totalPaymentsCount = allPayments.Count();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando datos del dashboard: {ex}");
            // Considera mostrar un mensaje de error en la UI también
        }
        finally
        {
            isLoading = false;
        }
    }

}