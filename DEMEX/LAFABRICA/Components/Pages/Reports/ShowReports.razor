@page "/reportes"
@inject IJSRuntime JSRuntime
@inherits LAFABRICA.Pages.ShowReports
@using LAFABRICA.Data.DB
@using LAFABRICA.Models.Interface

<PageTitle>Reportes y Análisis</PageTitle>

<style>

	/* --- Estilos Originales (Métricas y Gráficos) --- */
		.metric-card-icon-bg {
				width: 40px;
				height: 40px;
				border-radius: 50%;
				display: flex;
				align-items: center;
				justify-content: center;
				opacity: 0.8;

	}

		.metric-card-content {
				padding: 1rem;

	}

		.tab-content-padding {
				padding-top: 1.5rem;

	}

		.btn i.bi, .form-select i.bi {
				margin-right: 0.5rem;

	}


	/* Estilo para que el canvas se ajuste */
		.chart-container {
				position: relative;
				height: 300px;
				width: 100%;

	}


	/* --- NUEVOS ESTILOS PARA LAS PESTAÑAS (Tabs) --- */

	/* Contenedor principal de las pestañas */
		#reportTabs.nav-tabs {
				border-bottom: 1px solid #dee2e6;

	}


	/* Estilo para los botones de las pestañas (Estado Inactivo) */
		#reportTabs .nav-link {
				font-weight: 500;
				color: #555;
				border: none;
				border-top-left-radius: 0.375rem;
				border-top-right-radius: 0.375rem;

	}


	/* Estilo para pestaña INACTIVA al pasar el mouse */
			#reportTabs .nav-link:not(.active):hover {
					color: #893914;
					background-color: #f8f9fa;
					border-color: transparent;

	}


	/* Estilo para la pestaña ACTIVA (el más importante) */
			#reportTabs .nav-link.active {
					color: #ffffff;
					background-color: #6a4028;
					border-color: transparent;

	}
</style>

<div class="container-fluid mt-3">
	@if (isLoading)
	{
		<div class="text-center p-4">
			<div class="spinner-border text-primary" role="status">
				<span class="visually-hidden">Loading...</span>
			</div>
			<p class="mt-2">Cargando datos de reportes...</p>
		</div>
	}
	else
	{
		<div class="card mb-4 shadow-sm">
			<div class="card-header">
				<div class="d-flex justify-content-between align-items-center flex-wrap">
					<h4 class="mb-0">
						<i class="bi bi-bar-chart-line-fill me-2"></i> Reportes y Análisis
					</h4>

					<div class="d-flex align-items-center gap-2 mt-2 mt-md-0">
						<select class="form-select form-select-sm w-auto" value="@selectedPeriod" @onchange="OnPeriodChangedViaEvent">
							@foreach (var period in periodOptions)
							{
								<option value="@period">@period</option>
							}
						</select>
					</div>
				</div>
			</div>

			<div class="card-body">
				<div class="row mb-4">
					<div class="col-xl-3 col-md-6 mb-3">
						<div class="card shadow-sm h-100">
							<div class="card-body metric-card-content">
								<div class="d-flex justify-content-between align-items-center">
									<div>
										<p class="text-muted small mb-0">Ventas Totales</p>
										<h4 class="mb-0 fw-bold">@FormatPrice(totalSales)</h4>
									</div>
									<div class="metric-card-icon-bg" style="background-color: rgba(24, 145, 130, 0.1);">
										<i class="bi bi-currency-dollar text-success fs-5"></i>
									</div>
								</div>
								<div class="d-flex align-items-center mt-1 small text-success">
									<i class="bi bi-arrow-up me-1"></i>
									<span>+12.5%</span>
								</div>
							</div>
						</div>
					</div>
					<div class="col-xl-3 col-md-6 mb-3">
						<div class="card shadow-sm h-100">
							<div class="card-body metric-card-content">
								<div class="d-flex justify-content-between align-items-center">
									<div>
										<p class="text-muted small mb-0">Total Órdenes</p>
										<h4 class="mb-0 fw-bold">@totalOrders</h4>
									</div>
									<div class="metric-card-icon-bg" style="background-color: rgba(15, 84, 161, 0.1);">
										<i class="bi bi-box-seam text-primary fs-5"></i>
									</div>
								</div>
								<div class="d-flex align-items-center mt-1 small text-success">
									<i class="bi bi-arrow-up me-1"></i>
									<span>+8.3%</span>
								</div>
							</div>
						</div>
					</div>
					<div class="col-xl-3 col-md-6 mb-3">
						<div class="card shadow-sm h-100">
							<div class="card-body metric-card-content">
								<div class="d-flex justify-content-between align-items-center">
									<div>
										<p class="text-muted small mb-0">Valor Promedio</p>
										<h4 class="mb-0 fw-bold">@FormatPrice(avgOrderValue)</h4>
									</div>
									<div class="metric-card-icon-bg" style="background-color: rgba(137, 57, 20, 0.1);">
										<i class="bi bi-graph-up text-warning fs-5"></i>
									</div>
								</div>
								<div class="d-flex align-items-center mt-1 small text-success">
									<i class="bi bi-arrow-up me-1"></i>
									<span>+4.2%</span>
								</div>
							</div>
						</div>
					</div>
					<div class="col-xl-3 col-md-6 mb-3">
						<div class="card shadow-sm h-100">
							<div class="card-body metric-card-content">
								<div class="d-flex justify-content-between align-items-center">
									<div>
										<p class="text-muted small mb-0">Clientes Activos</p>
										<h4 class="mb-0 fw-bold">@activeClientsCount</h4>
									</div>
									<div class="metric-card-icon-bg" style="background-color: rgba(235, 207, 79, 0.1);">
										<i class="bi bi-people-fill text-info fs-5"></i>
									</div>
								</div>
								<div class="d-flex align-items-center mt-1 small text-success">
									<i class="bi bi-arrow-up me-1"></i>
									<span>+15.7%</span>
								</div>
							</div>
						</div>
					</div>
				</div>

				<ul class="nav nav-tabs" id="reportTabs" role="tablist">
					<li class="nav-item" role="presentation">
						<button class="nav-link @(selectedTab == "sales" ? "active" : "")" id="sales-tab" data-bs-toggle="tab" data-bs-target="#sales-tab-pane" type="button" role="tab" @onclick='() => selectedTab = "sales"'>
							<i class="bi bi-graph-up me-1"></i> Ventas
						</button>
					</li>
					<li class="nav-item" role="presentation">
						<button class="nav-link @(selectedTab == "products" ? "active" : "")" id="products-tab" data-bs-toggle="tab" data-bs-target="#products-tab-pane" type="button" role="tab" @onclick='() => selectedTab = "products"'>
							<i class="bi bi-box-seam-fill me-1"></i> Productos
						</button>
					</li>
					<li class="nav-item" role="presentation">
						<button class="nav-link @(selectedTab == "inventory" ? "active" : "")" id="inventory-tab" data-bs-toggle="tab" data-bs-target="#inventory-tab-pane" type="button" role="tab" @onclick='() => selectedTab = "inventory"'>
							<i class="bi bi-archive-fill me-1"></i> Inventario
						</button>
					</li>
					<li class="nav-item" role="presentation">
						<button class="nav-link @(selectedTab == "clients" ? "active" : "")" id="clients-tab" data-bs-toggle="tab" data-bs-target="#clients-tab-pane" type="button" role="tab" @onclick='() => selectedTab = "clients"'>
							<i class="bi bi-people-fill me-1"></i> Clientes
						</button>
					</li>
				</ul>
				<div class="tab-content border border-top-0 p-3" id="reportTabsContent">
					<div class="tab-pane fade @(selectedTab == "sales" ? "show active" : "")" id="sales-tab-pane" role="tabpanel">
						<div class="tab-content-padding">
							<div class="row">
								<div class="col-lg-6 mb-4">
									<div class="card shadow-sm h-100">
										<div class="card-header">
											<h5 class="card-title mb-0">Tendencia de Ventas</h5>
											<small class="text-muted">Ventas mensuales en el período</small>
										</div>
										<div class="card-body chart-container">
											<canvas id="salesChartCanvas"></canvas>
										</div>
									</div>
								</div>
								<div class="col-lg-6 mb-4">
									<div class="card shadow-sm h-100">
										<div class="card-header">
											<h5 class="card-title mb-0">Órdenes por Mes</h5>
											<small class="text-muted">Número de órdenes procesadas mensualmente</small>
										</div>
										<div class="card-body chart-container">
											<canvas id="ordersChartCanvas"></canvas>
										</div>
									</div>
								</div>
							</div>
						</div>
					</div>
					<div class="tab-pane fade @(selectedTab == "products" ? "show active" : "")" id="products-tab-pane" role="tabpanel">
						<div class="tab-content-padding">
							<div class="row">
								<div class="col-lg-6 mb-4">
									<div class="card shadow-sm h-100">
										<div class="card-header">
											<h5 class="card-title mb-0">Ventas por Categoría</h5>
											<small class="text-muted">Distribución de ventas por tipo de producto</small>
										</div>
										<div class="card-body chart-container">
											<canvas id="categoryChartCanvas"></canvas>
										</div>
									</div>
								</div>
								<div class="col-lg-6 mb-4">
									<div class="card shadow-sm h-100">
										<div class="card-header">
											<h5 class="card-title mb-0">Productos Más Vendidos</h5>
											<small class="text-muted">Top 5 productos por cantidad vendida</small>
										</div>
										<div class="card-body">
											<ul class="list-group list-group-flush">
												@foreach (var (product, index) in topProductsPlaceholder.Select((p, i) => (p, i)))
												{
													<li class="list-group-item d-flex justify-content-between align-items-center">
														<span>@(index + 1). @product.Key</span>
														<span class="badge bg-primary rounded-pill">@product.Value</span>
													</li>
												}
											</ul>
										</div>
									</div>
								</div>
							</div>
						</div>
					</div>
					<div class="tab-pane fade @(selectedTab == "inventory" ? "show active" : "")" id="inventory-tab-pane" role="tabpanel">
						<div class="tab-content-padding">
							<div class="card shadow-sm h-100">

								<div class="card-header">
									<h5 class="card-title mb-0">Alertas de Stock de Materiales</h5>
									<small class="text-muted">Materiales con inventario igual o inferior al mínimo requerido.</small>
								</div>
								<div class="card-body">
									<table class="table table-sm table-striped table-hover">
										<thead> <tr><th>Material</th><th class="text-center">Actual</th><th class="text-center">Mínimo</th><th class="text-end">Estado</th></tr> </thead>
										<tbody>
											@foreach (var alert in inventoryAlertsPlaceholder)
											{
												<tr><td>@alert.material</td><td class="text-center">@alert.currentStock</td><td class="text-center">@alert.minStock</td><td class="text-end"><span class="badge rounded-pill @(alert.status == "Agotado" ? "bg-danger" : "bg-warning text-dark")">@alert.status</span></td></tr>
											}
											@if (!inventoryAlertsPlaceholder.Any())
											{
												<tr><td colspan="4" class="text-center text-muted">No hay materiales con stock bajo.</td></tr>
											}
										</tbody>
									</table>
								</div>


							</div>
						</div>
					</div>
					<div class="tab-pane fade @(selectedTab == "clients" ? "show active" : "")" id="clients-tab-pane" role="tabpanel">
						<div class="tab-content-padding">
							<div class="card shadow-sm h-100">
								<div class="card-header">
									<h5 class="card-title mb-0">Mejores Clientes</h5>
									<small class="text-muted">Clientes con mayor volumen de compras</small>
								</div>
								<div class="card-body">
									<table class="table table-sm table-striped table-hover">
										<thead><tr><th class="text-center">#</th><th>Cliente</th><th class="text-center">Órdenes</th><th class="text-end">Total</th></tr></thead>
										<tbody>
											@foreach (var client in topClientsPlaceholder)
											{
												<tr><td class="text-center">@client.Rank</td><td>@client.name</td><td class="text-center">@client.orders</td><td class="text-end">@FormatPrice(client.total)</td></tr>
											}
											@if (!topClientsPlaceholder.Any())
											{
												<tr><td colspan="4" class="text-center text-muted">No hay datos de clientes para mostrar.</td></tr>
											}
										</tbody>
									</table>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	}
</div>