@page "/ordenes"
@attribute [Authorize]
@using LAFABRICA.Data.DB
@using LAFABRICA.Models.Interface
@using LAFABRICA.Models
@using LAFABRICA.Components.Pages.Product
@using LAFABRICA.Components.Pages.Order
@using LAFABRICA.Services.Auth
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject IOrderService orderService
@inject ToastService ToastService
@inject NavigationManager nav

<PageTitle>Gestión de Órdenes</PageTitle>

<Toasts class="p-3" Autohide="true" Delay="4000" Placement="ToastsPlacement.TopRight" />
<ConfirmDialog @ref="dialog" />
<OrderDetailsModal @ref="detailsModal" />

@if (user == null)
{
    <div class="text-center p-5">
        <Spinner Color="SpinnerColor.Primary" />
        <p>Cargando autenticación...</p>
    </div>
}
else if (!HasPermission("Orders", DemexClaims.View))
{
    <Alert Color="AlertColor.Warning" class="mt-4">
        <strong>No tienes permiso</strong> para ver las órdenes.
    </Alert>
}
else if (orders == null)
{
    <div class="d-flex justify-content-center">
        <Spinner Type="SpinnerType.Border" Size="SpinnerSize.Large" />
    </div>
}
else if (!InitialLoadComplete || !filteredOrders.Any())
{
    <div>
        <Alert Color="AlertColor.Primary" class="d-flex justify-content-between align-items-center">
            <div>
                <Icon Name="IconName.InfoCircleFill" class="me-2" />
                <strong>No hay órdenes activas registradas @(string.IsNullOrEmpty(searchText) && string.IsNullOrEmpty(selectedState) ? "" : "que coincidan con los filtros")</strong>
            </div>
            <div class="d-flex gap-2">
                <a class="btn btn-outline-success" href="/ordenes/completadas">
                    <Icon Name="IconName.CheckCircle" /> Órdenes Completadas
                </a>
                @if (HasPermission("Orders", DemexClaims.Create))
                {
                    <a class="btn btn-outline-primary" href="/ordenes/crear">
                        <Icon Name="IconName.PlusLg" /> Nueva Orden
                    </a>
                }
            </div>
        </Alert>
    </div>
}
else
{
    <div class="container mt-2">
        <div class="card">
            <div class="card-header">
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <h3><Icon Name="IconName.FileTextFill"></Icon> Gestión de Órdenes</h3>
                    <div class="d-flex gap-2">
                        <a class="btn btn-success" href="/ordenes/completadas">
                            <Icon Name="IconName.CheckCircle" /> Órdenes Completadas
                        </a>
                        @if (HasPermission("Orders", DemexClaims.Create))
                        {
                            <a class="btn btn-primary" href="/ordenes/crear">
                                <Icon Name="IconName.PlusLg"></Icon> Nueva Orden
                            </a>
                        }
                    </div>
                </div>
                <div class="d-flex flex-wrap justify-content-sm-start align-items-center gap-3 mt-3">
                    <div class="d-flex align-items-center border rounded px-2">
                        <Icon Name="IconName.Search" class="text-secondary me-2" />
                        <input type="text" class="form-control border-0" @bind="searchText" @bind:event="oninput" placeholder="Buscar por Cliente, ID..." style="box-shadow:none;" />
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <Icon Name="IconName.Funnel" class="text-secondary" />
                        <InputSelect class="form-select form-select-sm" @bind-Value="selectedState">
                            <option value="">Todos los estados</option>
                            @foreach (var state in states)
                            {
                                <option value="@state">@state</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="text-muted small">Ordenar por:</span>
                        <button class="btn btn-outline-secondary btn-sm @(sortField == "Priority" ? "active" : "")" @onclick='() => ApplySort("Priority")'>
                            Prioridad
                            @if (sortField == "Priority")
                            {
                                <Icon Name="@(sortAscending == true ? IconName.ArrowUp : IconName.ArrowDown)" />
                            }
                        </button>
                        <button class="btn btn-outline-secondary btn-sm @(sortField == "Date" ? "active" : "")" @onclick='() => ApplySort("Date")'>
                            Fecha
                            @if (sortField == "Date")
                            {
                                <Icon Name="@(sortAscending == true ? IconName.ArrowUp : IconName.ArrowDown)" />
                            }
                        </button>
                        @if (sortField != null)
                        {
                            <button class="btn btn-outline-danger btn-sm" @onclick='() => ApplySort(null)' title="Quitar ordenamiento">
                                <Icon Name="IconName.X" />
                            </button>
                        }
                    </div>
                </div>
            </div>
            <div class="card-body text-center">
                <div class="row">
                    <div class="col-12 table-responsive" style="max-height: 370px; overflow-y: auto;">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Cliente</th>
                                    <th>Fecha Creación</th>
                                    <th>Ubicación</th>
                                    <th>Estado</th>
                                    <th>Prioridad</th>
                                    <th>Total</th>
                                    <th>Adelanto</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var (ord, index) in filteredOrders.Select((o, i) => (o, i)))
                                {
                                    <tr>
                                        <td>@(index + 1)</td>
                                        <td>@ord.Client?.Name</td>
                                        <td>@ord.CreationDate.ToString("d")</td>
                                        <td>@ord.Client?.Location</td>
                                        <td><Badge Color="@GetStateBadgeColor(ord.State)">@ord.State</Badge></td>
                                        <td><Badge Color="@GetPriorityBadgeColor(ord.Priority)">@ord.Priority</Badge></td>
                                        <td>@ord.TotalAmount.ToString("C", new System.Globalization.CultureInfo("es-CR"))</td>
                                        <td>@ord.Advancement.ToString("C", new System.Globalization.CultureInfo("es-CR"))</td>
                                        <td>
                                            @if (HasPermission("Orders", DemexClaims.View))
                                            {
                                                <button class="btn btn-show" @onclick="() => detailsModal.ShowAsync(ord.Id)" title="Ver Detalles">
                                                    <Icon Name="IconName.Eye" Class="icon-show"/>
                                                </button>
                                            }

                                            @if (HasPermission("Orders", DemexClaims.Edit))
                                            {
                                                <button class="btn btn-edit" @onclick="() => EditOrder(ord)" title="Editar">
                                                    <Icon Name="IconName.PencilSquare" Class="icon-edit" />
                                                </button>
                                            }

                                            @if (HasPermission("Orders", DemexClaims.Delete))
                                            {
                                                <button class="btn btn-delete" @onclick="() => DeleteOrder(ord)" title="Eliminar">
                                                    <Icon Name="IconName.Trash" Color="IconColor.Danger"></Icon>
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="card-footer">
                <Icon Name="IconName.FileEarmarkText" /> Total de órdenes activas: @filteredOrders.Count()
            </div>
        </div>
    </div>
}

@code {
    // --- Autenticación y Claims ---
    [CascadingParameter] private Task<AuthenticationState>? authenticationStateTask { get; set; }
    private ClaimsPrincipal? user;

    private bool HasPermission(string module, string action)
        => user?.HasClaim($"can_{module.ToUpper()}_{action}", "True") ?? false;

    // --- Datos y estados ---
    private List<Order>? orders;
    private bool InitialLoadComplete = false;
    private ConfirmDialog dialog = default!;
    private OrderDetailsModal detailsModal = default!;

    private string searchText = string.Empty;
    private string selectedState = "";
    private List<string> states = new();

    private string? sortField = null;
    private bool? sortAscending = null;

    private IEnumerable<Order> filteredOrders
    {
        get
        {
            var query = orders?
                .Where(o => o.State != "Finalizada")
                .Where(o => string.IsNullOrEmpty(selectedState) || o.State == selectedState)
                .Where(o => string.IsNullOrEmpty(searchText) ||
                           (o.Client?.Name?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
                           o.Id.ToString().Contains(searchText))
                ?? Enumerable.Empty<Order>();

            if (!string.IsNullOrEmpty(sortField))
            {
                switch (sortField)
                {
                    case "Priority":
                        query = sortAscending == true
                            ? query.OrderBy(o => GetPriorityOrder(o.Priority)).ThenByDescending(o => o.Id)
                            : query.OrderByDescending(o => GetPriorityOrder(o.Priority)).ThenByDescending(o => o.Id);
                        break;
                    case "Date":
                        query = sortAscending == true
                            ? query.OrderBy(o => o.CreationDate).ThenByDescending(o => o.Id)
                            : query.OrderByDescending(o => o.CreationDate).ThenByDescending(o => o.Id);
                        break;
                }
            }
            else
            {
                query = query.OrderByDescending(o => o.Id);
            }

            return query;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await authenticationStateTask!;
        user = authState.User;
        await LoadOrders();
        InitialLoadComplete = true;
    }

    private async Task LoadOrders()
    {
        orders = (await orderService.GetAllOrders()).ToList();
        if (orders != null)
        {
            states = orders.Where(o => o.State != "Finalizada")
              .Select(o => o.State)
              .Distinct()
              .OrderBy(s => s)
              .ToList();
        }
    }

    private void ApplySort(string? field)
    {
        if (string.IsNullOrEmpty(field))
        {
            sortField = null;
            sortAscending = null;
        }
        else if (sortField == field)
        {
            if (sortAscending == false) sortAscending = true;
            else if (sortAscending == true) sortAscending = null;
            else sortAscending = false;

            if (sortAscending == null) sortField = null;
        }
        else
        {
            sortField = field;
            sortAscending = false;
        }
    }

    private int GetPriorityOrder(string priority)
    {
        return priority?.ToLower() switch
        {
            "alta" => 3,
            "media" => 2,
            "baja" => 1,
            _ => 0
        };
    }

    private void EditOrder(Order ord)
    {
        nav.NavigateTo($"/ordenes/editar/{ord.Id}");
    }

    private async Task DeleteOrder(Order order)
    {
        var options = new ConfirmDialogOptions
        {
            YesButtonText = "Eliminar",
            YesButtonColor = ButtonColor.Danger,
            NoButtonText = "Cancelar",
            NoButtonColor = ButtonColor.Secondary
        };

        var confirmation = await dialog.ShowAsync(
            title: "Eliminar Orden",
            message1: $"¿Estás seguro de eliminar la orden #{order.Id}?",
            message2: "Esta acción marcará la orden como inactiva.",
            confirmDialogOptions: options);

        if (confirmation)
        {
            try
            {
                await orderService.Delete(order.Id);
                await LoadOrders();
                ToastService.Notify(new(ToastType.Success, $"Se eliminó correctamente la orden #{order.Id}"));
            }
            catch (Exception e)
            {
                ToastService.Notify(new(ToastType.Danger, $"Ocurrió un error al tratar de eliminar la orden: {e.Message}"));
            }
        }
    }

    private BadgeColor GetStateBadgeColor(string state)
    {
        return state?.ToLower() switch
        {
            "diseño" => BadgeColor.Primary,
            "cotizando" => BadgeColor.Info,
            "entregable" => BadgeColor.Success,
            "corte" => BadgeColor.Dark,
            "acabados" => BadgeColor.Warning,
            _ => BadgeColor.Secondary
        };
    }

    private BadgeColor GetPriorityBadgeColor(string priority)
    {
        return priority?.ToLower() switch
        {
            "alta" => BadgeColor.Danger,
            "media" => BadgeColor.Warning,
            "baja" => BadgeColor.Info,
            _ => BadgeColor.Secondary
        };
    }
}


