@page "/ordenes/editar/{OrderId:int}"
@attribute [Authorize]
@using LAFABRICA.Data.DB
@using LAFABRICA.Models.Interface
@using LAFABRICA.Models
@using LAFABRICA.Services.Auth
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using System.ComponentModel.DataAnnotations
@inject IOrderService orderService
@inject IClientService clientService
@inject IProductService productService
@inject NavigationManager NavigationManager
@inject ToastService ToastService
@inject IJSRuntime JSRuntime
@inject IWebHostEnvironment WebHostEnvironment

<PageTitle>Editar Orden</PageTitle>

<Toasts class="p-3" Autohide="true" Delay="4000" Placement="ToastsPlacement.TopRight" />
<ConfirmDialog @ref="dialog" />

@if (user == null)
{
    <div class="text-center p-5">
        <Spinner Color="SpinnerColor.Primary" />
        <p>Cargando autenticación...</p>
    </div>
}
else if (!HasPermission("Orders", DemexClaims.View))
{
    <Alert Color="AlertColor.Warning" class="mt-4">
        <strong>No tienes permiso</strong> para ver o editar órdenes.
    </Alert>
}
else if (orderToEdit == null || allClients == null || allProducts == null)
{
    <div class="text-center p-4">
        <Spinner Color="SpinnerColor.Primary" />
        <p class="mt-2">Cargando datos de la orden...</p>
    </div>
}
else
{
    <EditForm EditContext="@editContext" OnValidSubmit="ShowConfirmationAsync">
        <DataAnnotationsValidator />
        <Card>
            <CardHeader>
                <CardTitle Size="HeadingSize.H5">
                    Editando Orden #@orderToEdit.Id - @orderToEdit.Client?.Name
                </CardTitle>
            </CardHeader>
            <CardBody>
                <ValidationSummary class="alert alert-danger mb-3" />

                <div class="row">
                    <div class="col-md-4">
                        <h5>1. Información del Cliente</h5>
                        <div class="mb-3">
                            <label class="form-label">Cliente *</label>
                            <InputSelect @bind-Value="orderToEdit.ClientId" class="form-select" 
                                         disabled="@(!HasPermission("Orders", DemexClaims.Edit))"
                                         @onchange="ClientSelectionChanged">
                                <option value="0">-- Seleccione un cliente --</option>
                                @foreach (var client in allClients)
                                {
                                    <option value="@client.Id">@client.Name</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => orderToEdit.ClientId)" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Prioridad de la Orden</label>
                            <InputSelect @bind-Value="orderToEdit.Priority" class="form-select"
                                         disabled="@(!HasPermission("Orders", DemexClaims.Edit))">
                                <option value="Baja">Baja</option>
                                <option value="Media">Media</option>
                                <option value="Alta">Alta</option>
                            </InputSelect>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Estado de la Orden</label>
                            <InputSelect @bind-Value="orderToEdit.State" class="form-select"
                                         disabled="@(!HasPermission("Orders", DemexClaims.Edit))">
                                <option value="Diseño">Diseño</option>
                                <option value="Corte">Corte</option>
                                <option value="Acabados">Acabados</option>
                                <option value="Entregable">Entregable</option>
                            </InputSelect>
                        </div>
                    </div>

                    <div class="col-md-8">
                        <h5>2. Productos de la Orden *</h5>

                        @if (!cartItems.Any())
                        {
                            <div class="alert alert-warning small">Debe añadir al menos un producto.</div>
                        }

                        @if (HasPermission("Orders", DemexClaims.Edit))
                        {
                            <div class="input-group mb-3">
                                <select @bind="selectedProductId" class="form-select" style="max-width: 60%;">
                                    <option value="0">-- Seleccione un producto para añadir --</option>
                                    @foreach (var product in allProducts)
                                    {
                                        <option value="@product.Id">@product.Name (@product.PriceBase.ToString("C"))</option>
                                    }
                                </select>
                                <InputNumber @bind-Value="selectedProductQuantity" class="form-control" placeholder="Cant." />
                                <Button Color="ButtonColor.Success" @onclick="AddProductToCart">Añadir</Button>
                            </div>
                        }

                        @if (cartItems.Any())
                        {
                            <ul class="list-group">
                                @foreach (var item in cartItems)
                                {
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        <span>@item.Quantity x @item.ProductName</span>
                                        <span class="fw-bold">@((item.Quantity * item.PriceBase).ToString("C"))</span>
                                        @if (HasPermission("Orders", DemexClaims.Edit))
                                        {
                                            <Button Color="ButtonColor.Danger" IsOutlined="true" Size="ButtonSize.Small" 
                                                    @onclick="() => RemoveProductFromCart(item.ProductId)">
                                                <Icon Name="IconName.Trash" />
                                            </Button>
                                        }
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <p class="text-muted text-center">No hay productos en esta orden.</p>
                        }
                    </div>
                </div>

                <hr class="my-4" />

                <h5>3. Resumen y Pago</h5>
                <div class="row">
                    <div class="col-md-4">
                        <label class="form-label">Total Acordado (₡) *</label>
                        <InputNumber @bind-Value="orderToEdit.TotalAmount" class="form-control"
                                     disabled="@(!HasPermission("Orders", DemexClaims.Edit))" />
                        <ValidationMessage For="@(() => orderToEdit.TotalAmount)" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Descuento (%)</label>
                        <InputNumber @bind-Value="orderToEdit.Discount" class="form-control"
                                     disabled="@(!HasPermission("Orders", DemexClaims.Edit))" />
                        @if (!string.IsNullOrEmpty(discountSuggestion))
                        {
                            <div class="form-text text-success">@discountSuggestion</div>
                        }
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Adelanto (₡)</label>
                        <InputNumber @bind-Value="orderToEdit.Advancement" class="form-control"
                                     disabled="@(!HasPermission("Orders", DemexClaims.Edit))" />
                        @if (orderToEdit.TotalAmount > 0)
                        {
                            <div class="form-text">Sugerido (50%): @((orderToEdit.TotalAmount * 0.5m).ToString("C"))</div>
                        }
                    </div>
                </div>
            </CardBody>

            <CardFooter>
                <div class="d-flex justify-content-end gap-2">
                    <a href="/ordenes" class="btn btn-secondary">Cancelar</a>

                    @if (HasPermission("Orders", DemexClaims.View))
                    {
                        <Button Color="ButtonColor.Info" IsOutlined="true"
                                @onclick="GeneratePdfPreview"
                                disabled="@(!cartItems.Any() || orderToEdit.ClientId == null)">
                            <Icon Name="IconName.FileEarmarkPdf" /> Generar Resumen
                        </Button>
                    }

                    @if (HasPermission("Orders", DemexClaims.Edit))
                    {
                        <button type="submit" class="btn btn-primary" disabled="@(!cartItems.Any())">
                            <Icon Name="IconName.Save" /> Guardar Cambios
                        </button>

                        <button type="button" class="btn btn-success" 
                                @onclick="ShowFinishConfirmationAsync" disabled="@(!cartItems.Any())">
                            <Icon Name="IconName.CheckCircle" /> Finalizar Orden
                        </button>
                    }
                </div>
            </CardFooter>
        </Card>
    </EditForm>
}

@code {
    [Parameter] public int OrderId { get; set; }

    [CascadingParameter] private Task<AuthenticationState>? authenticationStateTask { get; set; }
    private ClaimsPrincipal? user;

    private bool HasPermission(string module, string action)
        => user?.HasClaim($"can_{module.ToUpper()}_{action}", "True") ?? false;

    private Order? orderToEdit;
    private List<Client>? allClients;
    private List<Product>? allProducts;
    private List<CartItem> cartItems = new();
    private int selectedProductId;
    private int selectedProductQuantity = 1;
    private string discountSuggestion = "";
    private ConfirmDialog dialog = default!;
    private EditContext editContext = default!;

    public class CartItem
    {
        public int ProductId { get; set; }
        public string ProductName { get; set; } = "";
        public int Quantity { get; set; }
        public decimal PriceBase { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await authenticationStateTask!;
        user = authState.User;

        allClients = (await clientService.GetAllClient()).ToList();
        allProducts = (await productService.GetAllProducts()).ToList();
        orderToEdit = await orderService.GetById(OrderId);

        if (orderToEdit != null)
        {
            editContext = new EditContext(orderToEdit);
            cartItems = orderToEdit.ProductOrders.Select(po =>
            {
                var productDetails = allProducts?.FirstOrDefault(p => p.Id == po.IdProduct);
                return new CartItem
                {
                    ProductId = po.IdProduct,
                    Quantity = po.Quantity,
                    ProductName = productDetails?.Name ?? "Producto no encontrado",
                    PriceBase = productDetails?.PriceBase ?? 0
                };
            }).ToList();

            UpdateDiscountSuggestion();
        }
    }

    private void ClientSelectionChanged(ChangeEventArgs e)
    {
        if (orderToEdit is null) return;
        var clientId = int.Parse(e.Value?.ToString() ?? "0");
        orderToEdit.ClientId = clientId > 0 ? clientId : null;
        UpdateDiscountSuggestion();
        editContext?.NotifyFieldChanged(FieldIdentifier.Create(() => orderToEdit.ClientId));
    }

    private void AddProductToCart()
    {
        if (selectedProductId == 0 || selectedProductQuantity <= 0) return;
        var product = allProducts?.FirstOrDefault(p => p.Id == selectedProductId);
        if (product == null) return;

        var existingItem = cartItems.FirstOrDefault(i => i.ProductId == selectedProductId);
        if (existingItem != null)
        {
            existingItem.Quantity += selectedProductQuantity;
        }
        else
        {
            cartItems.Add(new CartItem
            {
                ProductId = product.Id,
                ProductName = product.Name,
                Quantity = selectedProductQuantity,
                PriceBase = product.PriceBase
            });
        }
        selectedProductId = 0;
        selectedProductQuantity = 1;
        UpdateDiscountSuggestion();
        StateHasChanged();
    }

    private void RemoveProductFromCart(int productId)
    {
        cartItems.RemoveAll(i => i.ProductId == productId);
        UpdateDiscountSuggestion();
        StateHasChanged();
    }

    private void UpdateDiscountSuggestion()
    {
        discountSuggestion = "";
        if (orderToEdit == null) return;
        var client = allClients?.FirstOrDefault(c => c.Id == orderToEdit.ClientId);
        bool isFrequent = client?.IsFrequent == 1;
        bool hasVolume = cartItems.Sum(i => i.Quantity) > 5;
        if (isFrequent && hasVolume) discountSuggestion = "Sugerencia: 5% (cliente frecuente y >5 artículos).";
        else if (isFrequent) discountSuggestion = "Sugerencia: 5% (cliente frecuente).";
        else if (hasVolume) discountSuggestion = "Sugerencia: 5% (más de 5 artículos).";
    }

    private void SyncProductList()
    {
        if (orderToEdit == null || allProducts == null) return;
        var productsToRemove = orderToEdit.ProductOrders
            .Where(dbProduct => !cartItems.Any(cartItem => cartItem.ProductId == dbProduct.IdProduct))
            .ToList();
        foreach (var product in productsToRemove)
        {
            orderToEdit.ProductOrders.Remove(product);
        }
        foreach (var cartItem in cartItems)
        {
            var existingProduct = orderToEdit.ProductOrders
                .FirstOrDefault(p => p.IdProduct == cartItem.ProductId);
            if (existingProduct != null)
            {
                existingProduct.Quantity = cartItem.Quantity;
            }
            else
            {
                var productDetails = allProducts.FirstOrDefault(p => p.Id == cartItem.ProductId);
                if (productDetails != null)
                {
                    orderToEdit.ProductOrders.Add(new ProductOrder
                    {
                        IdProduct = cartItem.ProductId,
                        Quantity = cartItem.Quantity,
                        IdOrderNavigation = orderToEdit,
                        IdProductNavigation = productDetails
                    });
                }
            }
        }
    }

    private async Task UpdateOrder()
    {
        if (orderToEdit == null) return;
        if (!cartItems.Any())
        {
            ToastService.Notify(new(ToastType.Warning, "Faltan Productos", "Debe haber al menos un producto para guardar los cambios."));
            return;
        }
        // Validar EditContext (DataAnnotations)
        if (!editContext.Validate())
        {
            ToastService.Notify(new(ToastType.Warning, "Datos incompletos", "Revise los campos marcados en rojo."));
            return;
        }

        try
        {
            SyncProductList();
            await orderService.Update(OrderId, orderToEdit);
            ToastService.Notify(new(ToastType.Success, "Orden Actualizada", "La orden ha sido guardada exitosamente."));
            NavigationManager.NavigateTo("/ordenes");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al actualizar orden: {ex}");
            ToastService.Notify(new(ToastType.Danger, "Error", $"No se pudo guardar la orden: {ex.Message}"));
        }
    }

    private async Task FinishOrder()
    {
        if (orderToEdit == null) return;
        if (!cartItems.Any())
        {
            ToastService.Notify(new(ToastType.Warning, "Faltan Productos", "Debe haber al menos un producto para finalizar la orden."));
            return;
        }
        // Validar EditContext (DataAnnotations)
        if (!editContext.Validate())
        {
            ToastService.Notify(new(ToastType.Warning, "Datos incompletos", "Revise los campos marcados en rojo."));
            return;
        }

        try
        {
            orderToEdit.State = "Finalizada";
            SyncProductList();
            await orderService.Update(OrderId, orderToEdit);
            await clientService.UpdateFrequentStatus(orderToEdit.ClientId!.Value);
            ToastService.Notify(new(ToastType.Success, "Orden Finalizada", "La orden ha sido completada exitosamente."));
            NavigationManager.NavigateTo("/ordenes");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al finalizar orden: {ex}");
            ToastService.Notify(new(ToastType.Danger, "Error", $"No se pudo finalizar la orden: {ex.Message}"));
        }
    }

    // === ShowConfirmationAsync CORREGIDO ===
    private async Task ShowConfirmationAsync()
    {
        // Validaciones previas
        if (!cartItems.Any())
        {
            ToastService.Notify(new(ToastType.Warning, "Faltan Productos", "Añada productos antes de guardar."));
            return;
        }
        if (!editContext.Validate())
        {
            ToastService.Notify(new(ToastType.Warning, "Datos incompletos", "Revise los campos marcados en rojo."));
            return;
        }

        // Definir opciones del diálogo
        var options = new ConfirmDialogOptions
        {
            YesButtonText = "Sí, guardar cambios",
            YesButtonColor = ButtonColor.Success,
            NoButtonText = "No, cancelar",
            NoButtonColor = ButtonColor.Secondary
        };
        // Mostrar diálogo CON ARGUMENTOS
        var confirmation = await dialog.ShowAsync(
            title: "¿Confirmar Cambios?",
            message1: $"¿Estás seguro de que deseas guardar las modificaciones para la orden #{orderToEdit?.Id}?",
            confirmDialogOptions: options); // Pasar las opciones

        if (confirmation)
        {
            await UpdateOrder();
        }
    }

    // === ShowFinishConfirmationAsync CORREGIDO ===
    private async Task ShowFinishConfirmationAsync()
    {
        // Validaciones previas
        if (!cartItems.Any())
        {
            ToastService.Notify(new(ToastType.Warning, "Faltan Productos", "Añada productos antes de finalizar."));
            return;
        }
        if (!editContext.Validate())
        {
            ToastService.Notify(new(ToastType.Warning, "Datos incompletos", "Revise los campos marcados en rojo."));
            return;
        }

        // Definir opciones del diálogo
        var options = new ConfirmDialogOptions
        {
            YesButtonText = "Sí, finalizar orden",
            YesButtonColor = ButtonColor.Success,
            NoButtonText = "No, cancelar",
            NoButtonColor = ButtonColor.Secondary
        };
        // Mostrar diálogo CON ARGUMENTOS
        var confirmation = await dialog.ShowAsync(
            title: "¿Confirmar Finalización?",
            message1: $"¿Estás seguro de que deseas marcar la orden #{orderToEdit?.Id} como finalizada?",
            message2: "Esta acción usualmente no se puede revertir.",
            confirmDialogOptions: options); // Pasar las opciones

        if (confirmation)
        {
            await FinishOrder();
        }
    }

    // Método GeneratePdfPreview (sin cambios respecto a la versión anterior)
    private async Task GeneratePdfPreview()
    {
        if (!cartItems.Any() || orderToEdit?.ClientId == null)
        {
            ToastService.Notify(new(ToastType.Warning, "Faltan datos", "Debe seleccionar un cliente y añadir al menos un producto."));
            return;
        }

        if (allProducts == null || orderToEdit == null)
        {
            ToastService.Notify(new(ToastType.Danger, "Error interno", "Los datos de la orden o productos no están cargados."));
            return;
        }

        var pdfProductOrders = cartItems.Select(item =>
        {
            var product = allProducts.FirstOrDefault(p => p.Id == item.ProductId);
            return new ProductOrder
            {
                IdProductNavigation = product,
                Quantity = item.Quantity,
                IdProduct = item.ProductId
            };
        }).ToList();

        var orderForPdf = new Order
        {
            Id = orderToEdit.Id,
            ClientId = orderToEdit.ClientId,
            TotalAmount = orderToEdit.TotalAmount,
            Discount = orderToEdit.Discount,
            Advancement = orderToEdit.Advancement,
            Priority = orderToEdit.Priority,
            State = orderToEdit.State,
            CreationDate = orderToEdit.CreationDate,
            ProductOrders = pdfProductOrders
        };

        var client = allClients?.FirstOrDefault(c => c.Id == orderToEdit.ClientId);
        if (client == null)
        {
            ToastService.Notify(new(ToastType.Warning, "Cliente no encontrado", "No se pudo encontrar el cliente seleccionado."));
            return;
        }

        var pdfModel = new OrderPdfModel
        {
            Order = orderForPdf,
            Client = client
        };

        var generator = new OrderPdfGenerator(pdfModel);
        var pdfBytes = generator.GenerateDocument();

        var fileName = $"Resumen_Orden_{orderToEdit.Id}_{client.Name?.Replace(" ", "_") ?? "Cliente"}_{DateTime.Now:yyyyMMdd}.pdf";
        var base64 = Convert.ToBase64String(pdfBytes);
        await JSRuntime.InvokeVoidAsync("saveAsFile", fileName, base64);
    }
}

