@page "/usuarios"
@attribute [Authorize]
@using LAFABRICA.Models
@using LAFABRICA.Data.DB
@using LAFABRICA.Models.Interface
@using LAFABRICA.Services.Auth
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject IUserService userService
@inject IEmployeePaymentService paymentService
@inject NavigationManager nav
@inject ToastService ToastService

<PageTitle>Usuarios</PageTitle>

<Modal @ref="modal" IsVerticallyCentered="true" Size="ModalSize.Large" />
<Toasts class="p-3" AutoHide="true" Delay="4000" Placement="ToastsPlacement.TopRight" />
<ConfirmDialog @ref="dialog" />
@if (user == null)
{
    <div class="d-flex justify-content-center">
        <Spinner Type="SpinnerType.Border" Size="SpinnerSize.Large" />
    </div>
}
else if (!HasPermission("Users", DemexClaims.View))
{
    <div class="text-center mt-5">
        <i class="bi bi-shield-lock fs-1 text-warning"></i>
        <h4 class="mt-3">Acceso denegado</h4>
        <p>No tienes permiso para ver usuarios.</p>
    </div>
}
else if (users == null)
{
    <div class="d-flex justify-content-center mt-5">
        <Spinner Type="SpinnerType.Border" Size="SpinnerSize.Large" />
    </div>
}
else if (!users.Any())
{
    <div>
        <Alert Color="AlertColor.Primary" class="d-flex justify-content-between align-items-center">
            <div>
                <Icon Name="IconName.InfoCircleFill" class="me-2" />
                <strong>No hay usuarios registrados</strong>
            </div>

            @if (HasPermission("Users", DemexClaims.Create))
            {
                <a class="btn btn-outline-primary" href="/usuarios/crear">
                    <Icon Name="IconName.PlusLg" /> Nuevo Usuario
                </a>
            }
        </Alert>
    </div>
}
else
{
    <div class="container mt-2">
        <div class="card shadow">
            <div class="card-header">
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <h3><Icon Name="IconName.PeopleFill" /> Gestión de Usuarios</h3>

                    @if (HasPermission("Users", DemexClaims.Create))
                    {
                        <a class="btn text-white" href="/usuarios/crear" style="background-color: #0f54a1;">
                            <Icon Name="IconName.PlusLg" /> Nuevo Usuario
                        </a>
                    }
                </div>

                <div class="d-flex justify-content-sm-start align-items-center gap-3 mt-3">
                    <div class="d-flex align-items-center border rounded px-2">
                        <Icon Name="IconName.Search" class="text-secondary me-2" />
                        <input type="text" class="form-control border-0"
                               @bind="searchText" @bind:event="oninput"
                               placeholder="Buscar usuario..." style="box-shadow:none;" />
                    </div>

                    <div class="d-flex align-items-center gap-2">
                        <Icon Name="IconName.Funnel" class="text-secondary" />
                        <InputSelect class="form-select" @bind-Value="selectedRole">
                            <option value="">Todos los roles</option>
                            @foreach (var role in roles)
                            {
                                <option value="@role">@role</option>
                            }
                        </InputSelect>
                    </div>
                </div>
            </div>

            <div class="card-body text-center">
                <div class="row">
                    <div class="col-12 table-responsive" style="max-height: 370px; overflow-y: auto;">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Nombre</th>
                                    <th>Identificación</th>
                                    <th>Correo</th>
                                    <th>Rol</th>
                                    <th>Especialidad</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var u in filteredUsers.Select((user, index) => new { user, index }))
                                {
                                    <tr>
                                        <td>@(u.index + 1)</td>
                                        <td>@u.user.Name</td>
                                        <td>@u.user.Identification</td>
                                        <td><Icon Name="IconName.EnvelopeAt" /> @u.user.Email</td>
                                        <td>@u.user.Rol?.Name</td>
                                        <td>@u.user.Speciality</td>
                                        <td>
                                            @if (HasPermission("Workers_Payments", DemexClaims.View))
                                            {
                                                <button class="btn btn-show" @onclick="() => ManagePayment(u.user)">
                                                    <Icon Name="IconName.CurrencyDollar" Class="icon-show" />
                                                </button>
                                            }

                                            
                                            @if (HasPermission("Users", DemexClaims.Edit))
                                            {
                                                <button class="btn btn-edit" @onclick="() => EditUser(u.user)">
                                                    <Icon Name="IconName.PencilSquare" Class="icon-edit " />
                                                </button>
                                            }

                                            
                                            @if (HasPermission("Users", DemexClaims.Delete))
                                            {
                                                <button class="btn btn-delete" @onclick="() => DeleteUser(u.user)">
                                                    <Icon Name="IconName.Trash" Color="IconColor.Danger" />
                                                </button>
                                            }

                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="card-footer">
                <Icon Name="IconName.PeopleFill" Color="IconColor.Primary" />
                Total de usuarios: @users.Count
            </div>
        </div>
    </div>
}

@code {
    private ClaimsPrincipal? user;

    private List<User>? users;
    private string searchText = string.Empty;
    private string selectedRole = "";
    private List<string> roles = new();
    private ConfirmDialog dialog = default!;
    private Modal modal = default!;

    private IEnumerable<User> filteredUsers =>
    users?
        .Where(u => u.Email != user?.FindFirstValue(ClaimTypes.Email))
        .Where(u => u.IsActive == 1)
        .Where(u => string.IsNullOrEmpty(selectedRole) || u.Rol != null && u.Rol.Name == selectedRole)
        .Where(u =>
            string.IsNullOrEmpty(searchText) ||
            u.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
            u.Email.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
            u.Identification.Contains(searchText, StringComparison.OrdinalIgnoreCase)
        )
        ?? [];


    [CascadingParameter] private Task<AuthenticationState>? authenticationStateTask { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var authState = await authenticationStateTask!;
        user = authState.User;

        if (HasPermission("Users", DemexClaims.View))
            await LoadUsers();
    }


    private bool HasPermission(string module, string action)
        => user?.HasClaim($"can_{module.ToUpper()}_{action}", "True") ?? false;

    private async Task LoadUsers()
    {
        users = (await userService.GetAllUsers()).ToList();
        roles = users.Select(u => u.Rol?.Name).Distinct().Where(r => !string.IsNullOrEmpty(r)).ToList()!;
    }

    private void EditUser(User user)
    {
        if (!HasPermission("Users", DemexClaims.Edit)) return;
        nav.NavigateTo($"/usuarios/editar/{user.Id}");
    }

    private async Task ManagePayment(User user)
    {
        if (!HasPermission("Users", DemexClaims.Edit)) return;

        var parameters = new Dictionary<string, object> { { "UserId", user.Id } };
        await modal.ShowAsync<UserPaymentView>(
            title: $"Pagos de {user.Name}",
            parameters: parameters
        );
    }


    private async Task DeleteUser(User user)
    {
        string messageSecondary = "Esta acción es irreversible.";
        if (!HasPermission("Users", DemexClaims.Delete))
        {
            ToastService.Notify(new(ToastType.Warning, "No tienes permiso para eliminar usuarios"));
            return;
        }

        var options = new ConfirmDialogOptions
        {
            YesButtonText = "Eliminar",
            YesButtonColor = ButtonColor.Danger,
            NoButtonText = "Cancelar",
            NoButtonColor = ButtonColor.Secondary
        };

        bool hasPendingPay = await paymentService.HasPendingPaymentAsync(user.Id);
        if (hasPendingPay)
            messageSecondary = "Este empleado tiene uno o más pagos pendientes";
       
        var confirm = await dialog.ShowAsync(
          "Eliminar usuario",
          $"¿Estás seguro de eliminar a {user.Name}?",
          messageSecondary,          
          options);

        if (confirm)
        {
            await userService.Delete(user.Id);
            await LoadUsers();
            ToastService.Notify(new(ToastType.Success, $"Usuario eliminado correctamente."));
        }
    }
}

