@page "/productos/editar/{ProductId:int}"
@attribute [Authorize]
@using LAFABRICA.Models
@using LAFABRICA.Data.DB
@using LAFABRICA.Models.Interface
@using LAFABRICA.Services.Auth
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject IProductService productService
@inject IMaterialService materialService
@inject NavigationManager NavigationManager
@inject ToastService ToastService
@inject IWebHostEnvironment WebHostEnvironment

<PageTitle>Editar Producto</PageTitle>

<Toasts class="p-3" Autohide="true" Delay="4000" Placement="ToastsPlacement.TopRight" />
<ConfirmDialog @ref="dialog" />

@if (user == null)
{
    <div class="text-center">
        <Spinner Color="SpinnerColor.Primary" />
        <p class="mt-2">Cargando autenticación...</p>
    </div>
}
else if (!HasPermission("Products", DemexClaims.Edit))
{
    <div class="text-center mt-5">
        <i class="bi bi-shield-lock fs-1 text-warning"></i>
        <h4 class="mt-3">Acceso denegado</h4>
        <p>No tienes permiso para editar productos.</p>
    </div>
}
else if (productToEdit == null)
{
    <div class="text-center">
        <Spinner Color="SpinnerColor.Primary" />
        <p class="mt-2">Cargando producto...</p>
    </div>
}
else
{
    <div class="card ">
        <div class="card-header">
            <div class="d-flex justify-content-between align-items-center mt-3">
                <h2>
                    <Icon Name="IconName.BagDashFill" class="me-2" />Editar Producto: @productToEdit.Name
                </h2>
                <a class="btn btn-outline-secondary" href="/productos"><Icon Name="IconName.ArrowLeft"></Icon></a>
            </div>
        </div>
        <div class="card-body">
            <EditForm Model="@productToEdit" OnValidSubmit="@ShowConfirmationAsync">
                <DataAnnotationsValidator />
                <ValidationSummary class="alert alert-danger" />

                <div class="row">
                    <div class="col-md-6">
                        <h5>Información Básica</h5>
                        <div class="mb-3">
                            <label class="form-label">Nombre del producto *</label>
                            <InputText @bind-Value="productToEdit.Name" class="@GetNameClass()" maxlength="50" />
                            <ValidationMessage For="@(() => productToEdit.Name)" />
                            <div class="d-flex justify-content-between mt-1">
                                <small class="text-muted">Máximo 50 caracteres</small>
                                <small class="@GetNameCounterClass()">
                                    @(productToEdit.Name?.Length ?? 0)/50
                                </small>
                            </div>
                            @if (NameHasError())
                            {
                                <div class="invalid-feedback d-block">
                                    El nombre no puede tener más de 50 caracteres
                                </div>
                            }
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Categoría *</label>
                            <InputSelect @bind-Value="productToEdit.Category" class="form-select">
                                <option value="">Seleccione una categoría</option>
                                <option value="Hogar y Decoración">Hogar y Decoración</option>
                                <option value="Regalos y Ocasiones">Regalos y Ocasiones</option>
                                <option value="Accesorios Personales">Accesorios Personales</option>
                                <option value="Cocina">Cocina</option>
                                <option value="Manualidades">Manualidades</option>
                            </InputSelect>
                            <ValidationMessage For="@(() => productToEdit.Category)" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Descripción</label>
                            <InputTextArea @bind-Value="productToEdit.Description" class="@GetDescriptionClass()" rows="3" maxlength="100" />
                            <div class="d-flex justify-content-between mt-1">
                                <small class="text-muted">Máximo 100 caracteres</small>
                                <small class="@GetDescriptionCounterClass()">
                                    @(productToEdit.Description?.Length ?? 0)/100
                                </small>
                            </div>
                            @if (DescriptionHasError())
                            {
                                <div class="invalid-feedback d-block">
                                    La descripción no puede tener más de 100 caracteres
                                </div>
                            }
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Precio base (₡) *</label>
                            <InputNumber @bind-Value="productToEdit.PriceBase" class="@GetPriceClass()" min="0" />
                            <ValidationMessage For="@(() => productToEdit.PriceBase)" />
                            @if (PriceHasError())
                            {
                                <div class="invalid-feedback d-block">
                                    El precio no puede ser negativo
                                </div>
                            }
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Cambiar Foto del Producto</label>
                            <InputFile OnChange="HandleFileSelected" class="@GetFileClass()" accept=".jpg,.jpeg,.png" />
                            @if (FileHasError())
                            {
                                <div class="invalid-feedback d-block">
                                    @fileValidationError
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(currentPhotoUrl))
                            {
                                <div class="mt-2 text-center">
                                    <p class="text-muted mb-1">Foto actual:</p>
                                    <img src="@currentPhotoUrl" alt="Foto actual" style="max-height: 150px; border-radius: 5px;" />
                                </div>
                            }
                            <small class="text-muted">Formatos permitidos: .jpg, .jpeg, .png</small>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <h5>Configuración Avanzada</h5>
                        <div class="mb-3 form-check form-switch fs-5">
                            <InputCheckbox @bind-Value="isCustomizable" class="form-check-input" id="customSwitch" />
                            <label class="form-check-label" for="customSwitch">Producto personalizable</label>
                        </div>

                        @if (isCustomizable)
                        {
                            <div class="mb-3">
                                <label class="form-label">Complejidad *</label>
                                <InputSelect @bind-Value="productToEdit.Complexity" class="form-select">
                                    <option value="">Seleccione complejidad</option>
                                    <option value="Muy baja">Muy baja</option>
                                    <option value="Baja">Baja</option>
                                    <option value="Media">Media</option>
                                    <option value="Alta">Alta</option>
                                    <option value="Muy alta">Muy alta</option>
                                </InputSelect>
                                <ValidationMessage For="@(() => productToEdit.Complexity)" />
                            </div>
                        }

                        <div class="mb-3">
                            <label class="form-label">Materiales</label>
                            @if (allMaterials == null)
                            {
                                <p>Cargando materiales...</p>
                            }
                            else
                            {
                                <div class="border rounded p-2" style="max-height: 200px; overflow-y: auto;">
                                    @foreach (var material in allMaterials)
                                    {
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox"
                                                   value="@material.Id"
                                                   checked="@(selectedMaterialIds.Contains(material.Id))"
                                                   @onchange="eventArgs => OnMaterialCheckboxChanged(material.Id, eventArgs.Value)" />
                                            <label class="form-check-label">@material.Name</label>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <hr class="my-4" />

                <div class="d-flex justify-content-end">
                    <a href="/productos" class="btn btn-outline-secondary me-2">Cancelar</a>
                    <button type="submit" class="btn btn-primary" disabled="@(!IsFormValid())">Guardar</button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;
    private ClaimsPrincipal? user;

    [Parameter] public int ProductId { get; set; }

    private Product? productToEdit;
    private bool isCustomizable;

    private IEnumerable<Material> allMaterials = null!;
    private HashSet<int> selectedMaterialIds = new();

    private IBrowserFile? selectedFile;
    private string? currentPhotoUrl;
    private string? fileValidationError;

    private ConfirmDialog dialog = default!;

    // Formatos de imagen permitidos - solo JPG y PNG
    private readonly string[] allowedImageTypes = new[]
    {
        "image/jpeg", "image/png"
    };

    private readonly string[] allowedExtensions = new[]
    {
        ".jpg", ".jpeg", ".png"
    };

    // Métodos para calcular clases condicionales
    private string GetNameClass() => $"form-control {(NameHasError() ? "is-invalid" : "")}";
    private string GetNameCounterClass() => NameHasError() ? "text-danger" : "text-muted";
    private bool NameHasError() => productToEdit?.Name?.Length > 50;

    private string GetDescriptionClass() => $"form-control {(DescriptionHasError() ? "is-invalid" : "")}";
    private string GetDescriptionCounterClass() => DescriptionHasError() ? "text-danger" : "text-muted";
    private bool DescriptionHasError() => productToEdit?.Description?.Length > 100;

    private string GetPriceClass() => $"form-control {(PriceHasError() ? "is-invalid" : "")}";
    private bool PriceHasError() => productToEdit?.PriceBase < 0;

    private string GetFileClass() => $"form-control {(FileHasError() ? "is-invalid" : "")}";
    private bool FileHasError() => !string.IsNullOrEmpty(fileValidationError);

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthenticationStateTask;
        user = auth.User;

        if (!HasPermission("Products", DemexClaims.Edit))
            return;

        try
        {
            productToEdit = await productService.GetById(ProductId);

            if (productToEdit != null)
            {
                isCustomizable = productToEdit.IsCustom == 1;
                currentPhotoUrl = productToEdit.PhotoUrl;
                allMaterials = await materialService.GetAllMaterials();
                selectedMaterialIds = productToEdit.ProductMaterials.Select(pm => pm.MaterialId).ToHashSet();

                // Asegurar que Complexity nunca sea null
                if (string.IsNullOrWhiteSpace(productToEdit.Complexity))
                {
                    productToEdit.Complexity = isCustomizable ? "" : "Muy baja";
                }
            }
        }
        catch (Exception ex)
        {
            ToastService.Notify(new(ToastType.Danger, $"No se pudo cargar el producto: {ex.Message}"));
            NavigationManager.NavigateTo("/productos");
        }
    }

    private bool HasPermission(string module, string action)
        => user?.HasClaim($"can_{module.ToUpper()}_{action}", "True") ?? false;

    private void OnMaterialCheckboxChanged(int materialId, object? checkedValue)
    {
        if (checkedValue is bool isChecked)
        {
            if (isChecked)
            {
                selectedMaterialIds.Add(materialId);
            }
            else
            {
                selectedMaterialIds.Remove(materialId);
            }
        }
    }

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        fileValidationError = null;
        selectedFile = e.File;

        // Validar tipo de archivo
        if (selectedFile != null)
        {
            // Validar por tipo MIME
            if (!allowedImageTypes.Contains(selectedFile.ContentType))
            {
                fileValidationError = "Tipo de archivo no permitido. Formatos aceptados: .jpg, .jpeg, .png";
                selectedFile = null;
                return;
            }

            // Validar por extensión
            var fileExtension = Path.GetExtension(selectedFile.Name).ToLowerInvariant();
            if (!allowedExtensions.Contains(fileExtension))
            {
                fileValidationError = "Tipo de archivo no permitido. Formatos aceptados: .jpg, .jpeg, .png";
                selectedFile = null;
                return;
            }

            // Validar tamaño del archivo (máximo 5MB)
            if (selectedFile.Size > 5 * 1024 * 1024)
            {
                fileValidationError = "El archivo es demasiado grande. Tamaño máximo permitido: 5MB";
                selectedFile = null;
                return;
            }
        }

        currentPhotoUrl = null;
        StateHasChanged();
    }

    private bool IsFormValid()
    {
        if (productToEdit == null) return false;

        // Validar nombre
        if (string.IsNullOrWhiteSpace(productToEdit.Name) || NameHasError())
            return false;

        // Validar categoría
        if (string.IsNullOrWhiteSpace(productToEdit.Category))
            return false;

        // Validar descripción
        if (DescriptionHasError())
            return false;

        // Validar precio
        if (PriceHasError())
            return false;

        // Validar archivo (si se seleccionó uno)
        if (FileHasError())
            return false;

        // Validar complejidad si es personalizable
        if (isCustomizable && string.IsNullOrWhiteSpace(productToEdit.Complexity))
            return false;

        return true;
    }

    // Método que guarda los cambios, ahora se llama desde la confirmación
    private async Task UpdateProduct()
    {
        if (productToEdit == null) return;

        try
        {
            // Validaciones adicionales antes de enviar
            if (NameHasError())
            {
                ToastService.Notify(new(ToastType.Danger, "El nombre no puede tener más de 50 caracteres"));
                return;
            }

            if (DescriptionHasError())
            {
                ToastService.Notify(new(ToastType.Danger, "La descripción no puede tener más de 100 caracteres"));
                return;
            }

            if (PriceHasError())
            {
                ToastService.Notify(new(ToastType.Danger, "El precio base no puede ser negativo"));
                return;
            }

            // Validar complejidad si es personalizable
            if (isCustomizable && string.IsNullOrWhiteSpace(productToEdit.Complexity))
            {
                ToastService.Notify(new(ToastType.Danger, "Debe seleccionar una complejidad para productos personalizables"));
                return;
            }

            // Asegurarse de que Complexity nunca sea null
            if (string.IsNullOrWhiteSpace(productToEdit.Complexity))
            {
                productToEdit.Complexity = "Muy baja";
            }

            if (selectedFile != null)
            {
                var uploadsFolder = Path.Combine(WebHostEnvironment.WebRootPath, "images", "products");
                if (!Directory.Exists(uploadsFolder)) Directory.CreateDirectory(uploadsFolder);

                var uniqueFileName = $"{Guid.NewGuid()}{Path.GetExtension(selectedFile.Name)}";
                var filePath = Path.Combine(uploadsFolder, uniqueFileName);

                await using (var fileStream = new FileStream(filePath, FileMode.Create))
                {
                    await selectedFile.OpenReadStream(maxAllowedSize: 5242880).CopyToAsync(fileStream);
                }

                productToEdit.PhotoUrl = $"/images/products/{uniqueFileName}";
            }

            productToEdit.IsCustom = isCustomizable ? (byte)1 : (byte)0;

            // Si no es personalizable, forzar complejidad "Muy baja"
            if (!isCustomizable)
            {
                productToEdit.Complexity = "Muy baja";
            }

            productToEdit.ProductMaterials = selectedMaterialIds.Select(id => new ProductMaterial { ProductId = ProductId, MaterialId = id }).ToList();

            await productService.Update(ProductId, productToEdit);

            ToastService.Notify(new(ToastType.Success, "Producto Actualizado", $"'{productToEdit.Name}' se actualizó correctamente."));
            NavigationManager.NavigateTo("/productos");
        }
        catch (Exception ex)
        {
            ToastService.Notify(new(ToastType.Danger, "Error al Actualizar", $"No se pudo guardar el producto: {ex.Message}"));
        }
    }

    // Nuevo método que se llama al enviar el formulario
    private async Task ShowConfirmationAsync()
    {
        // Primero validamos el formulario antes de mostrar la confirmación
        if (!IsFormValid())
        {
            ToastService.Notify(new(ToastType.Danger, "Error de validación", "Por favor, corrija los errores en el formulario antes de guardar."));
            return;
        }

        var options = new ConfirmDialogOptions
        {
            YesButtonText = "Confirmar",
            YesButtonColor = ButtonColor.Success,
            NoButtonText = "Cancelar",
            NoButtonColor = ButtonColor.Danger
        };

        var confirmation = await dialog.ShowAsync(
            title: "¿Confirmar Cambios?",
            message1: $"¿Estás seguro de que deseas guardar las modificaciones para '{productToEdit?.Name}'?",
            message2: "Esta acción sobrescribirá los datos anteriores.",
            confirmDialogOptions: options);

        if (confirmation)
        {
            // Si el usuario confirma, entonces llamamos al método para guardar
            await UpdateProduct();
        }
    }
}