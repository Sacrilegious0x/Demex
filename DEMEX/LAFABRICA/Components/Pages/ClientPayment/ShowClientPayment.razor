@page "/pagos"
@attribute [Authorize]
@using LAFABRICA.Data.DB
@using LAFABRICA.Models
@using LAFABRICA.Models.Interface
@using LAFABRICA.Services.Auth
@using LAFABRICA.Components.Pages.ClientPayment
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject IClientPaymentService paymentService
@inject IOrderService orderService
@inject ToastService ToastService
@inject NavigationManager nav

<PageTitle>Gestión de Pagos</PageTitle>

<Toasts class="p-3" Autohide="true" Delay="4000" Placement="ToastsPlacement.TopRight" />
<ConfirmDialog @ref="dialog" />
<ClientPaymentDetailsModal @ref="detailsModal" />

@if (user == null)
{
    <div class="text-center p-5">
        <Spinner Color="SpinnerColor.Primary" />
        <p>Cargando autenticación...</p>
    </div>
}
else if (!HasPermission("Clients_Payments", DemexClaims.View))
{
    <Alert Color="AlertColor.Warning" class="mt-4">
        <strong>No tienes permiso</strong> para ver la gestión de pagos.
    </Alert>
}
else if (payments == null)
{
    <div class="d-flex justify-content-center">
        <Spinner Type="SpinnerType.Border" Size="SpinnerSize.Large" />
        <p class="mt-2 ms-2">Cargando pagos...</p>
    </div>
}
else if (!InitialLoadComplete || !filteredPayments.Any())
{
    <div>
        <Alert Color="AlertColor.Primary" class="d-flex justify-content-between align-items-center">
            <div>
                <Icon Name="IconName.InfoCircleFill" class="me-2" />
                <strong>No hay pagos registrados @(string.IsNullOrEmpty(searchText) && !filterStartDate.HasValue && !filterEndDate.HasValue ? "" : "que coincidan con los filtros")</strong>
            </div>
            @if (HasPermission("Clients_Payments", DemexClaims.Create))
            {
                <a class="btn btn-outline-primary" href="/pagos/registrar">
                    <Icon Name="IconName.PlusLg" /> Registrar Pago
                </a>
            }
        </Alert>
    </div>
}
else
{
    <div class="container mt-2">
        <div class="card">
            <div class="card-header">
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <h3><Icon Name="IconName.CashCoin"></Icon> Gestión de Pagos</h3>
                    @if (HasPermission("Clients_Payments", DemexClaims.Create))
                    {
                        <a class="btn btn-primary" href="/pagos/registrar">
                            <Icon Name="IconName.PlusLg"></Icon> Registrar Pago
                        </a>
                    }
                </div>

                <div class="d-flex flex-wrap justify-content-sm-start align-items-center gap-3 mt-3">
                    <div class="d-flex align-items-center border rounded px-2">
                        <Icon Name="IconName.Search" class="text-secondary me-2" />
                        <input type="text" class="form-control border-0" @bind="searchText" @bind:event="oninput"
                               placeholder="Buscar por #Orden, #Pago, Método..." style="box-shadow:none;" />
                    </div>

                    <div class="d-flex align-items-center gap-2">
                        <Icon Name="IconName.Calendar" class="text-secondary" />
                        <label class="form-label small mb-0">Desde:</label>
                        <InputDate @bind-Value="filterStartDate" class="form-control form-control-sm" />
                        <label class="form-label small mb-0 ms-2">Hasta:</label>
                        <InputDate @bind-Value="filterEndDate" class="form-control form-control-sm" />
                        @if (filterStartDate.HasValue || filterEndDate.HasValue)
                        {
                            <button class="btn btn-outline-danger btn-sm" @onclick="ClearDateFilters" title="Limpiar fechas">
                                <Icon Name="IconName.X" />
                            </button>
                        }
                    </div>
                </div>
            </div>

            <div class="card-body text-center">
                <div class="row">
                    <div class="col-12 table-responsive" style="max-height: 450px; overflow-y: auto;">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th># Pago</th>
                                    <th># Orden</th>
                                    <th>Cliente</th>
                                    <th>Fecha Pago</th>
                                    <th>Monto</th>
                                    <th>Método</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var payment in filteredPayments)
                                {
                                    <tr>
                                        <td>@payment.Id</td>
                                        <td>@payment.OrderId</td>
                                        <td>@payment.Order?.Client?.Name</td>
                                        <td>@payment.PaymentDate.ToString("d")</td>
                                        <td class="text-end">@payment.Amount.ToString("C", new System.Globalization.CultureInfo("es-CR"))</td>
                                        <td>@payment.PaymentMethod</td>
                                        <td>
                                            @if (HasPermission("Clients_Payments", DemexClaims.View))
                                            {
                                                <button class="btn btn-show" @onclick="() => detailsModal.ShowAsync(payment.Id)" title="Ver Detalles">
                                                    <Icon Name="IconName.Eye" Class="icon-show" />
                                                </button>
                                            }

                                            @if (HasPermission("Clients_Payments", DemexClaims.Delete))
                                            {
                                                <button class="btn btn-delete" @onclick="() => DeletePaymentConfirmation(payment)" title="Eliminar">
                                                    <Icon Name="IconName.Trash" Color="IconColor.Danger"></Icon>
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="card-footer">
                <Icon Name="IconName.CashStack" /> Total de pagos mostrados: @filteredPayments.Count()
            </div>
        </div>
    </div>
}

@code {
    // === Autenticación y permisos ===
    [CascadingParameter] private Task<AuthenticationState>? authenticationStateTask { get; set; }
    private ClaimsPrincipal? user;

    private bool HasPermission(string module, string action)
        => user?.HasClaim($"can_{module.ToUpper()}_{action}", "True") ?? false;

    private List<ClientPayment>? payments;
    private bool InitialLoadComplete = false;
    private ConfirmDialog dialog = default!;
    private ClientPaymentDetailsModal detailsModal = default!;

    private string searchText = string.Empty;
    private DateTime? filterStartDate;
    private DateTime? filterEndDate;

    private IEnumerable<ClientPayment> filteredPayments =>
        payments?
            .Where(p => !filterStartDate.HasValue || p.PaymentDate >= DateOnly.FromDateTime(filterStartDate.Value))
            .Where(p => !filterEndDate.HasValue || p.PaymentDate <= DateOnly.FromDateTime(filterEndDate.Value))
            .Where(p => string.IsNullOrEmpty(searchText) ||
                        p.Id.ToString().Contains(searchText) ||
                        p.OrderId.ToString().Contains(searchText) ||
                        (p.PaymentMethod?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
                        (p.Order?.Client?.Name?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false))
            .OrderByDescending(p => p.PaymentDate)
            .ThenByDescending(p => p.Id)
        ?? Enumerable.Empty<ClientPayment>();

    protected override async Task OnInitializedAsync()
    {
        var authState = await authenticationStateTask!;
        user = authState.User;

        await LoadPayments();
        InitialLoadComplete = true;
    }

    private async Task LoadPayments()
    {
        try
        {
            payments = (await paymentService.GetAllPayments()).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando pagos: {ex.Message}");
            ToastService.Notify(new(ToastType.Danger, "Error", "No se pudieron cargar los pagos."));
            payments = new List<ClientPayment>();
        }
    }

    private void ClearDateFilters()
    {
        filterStartDate = null;
        filterEndDate = null;
    }

    private async Task DeletePaymentConfirmation(ClientPayment payment)
    {
        if (!HasPermission("Payments", DemexClaims.Delete))
        {
            ToastService.Notify(new(ToastType.Warning, "Sin permiso", "No tienes permiso para eliminar pagos."));
            return;
        }

        var options = new ConfirmDialogOptions
        {
            YesButtonText = "Eliminar",
            YesButtonColor = ButtonColor.Danger,
            NoButtonText = "Cancelar",
            NoButtonColor = ButtonColor.Secondary
        };

        var confirmation = await dialog.ShowAsync(
            title: "Eliminar Pago",
            message1: $"¿Estás seguro de eliminar el pago #{payment.Id} por {payment.Amount:C}?",
            message2: "Esta acción no se puede deshacer.",
            confirmDialogOptions: options);

        if (confirmation)
            await DeletePayment(payment.Id);
    }

    private async Task DeletePayment(int paymentId)
    {
        try
        {
            bool deleted = await paymentService.DeletePayment(paymentId);
            if (deleted)
            {
                await LoadPayments();
                ToastService.Notify(new(ToastType.Success, $"Se eliminó correctamente el pago #{paymentId}"));
            }
            else
            {
                ToastService.Notify(new(ToastType.Warning, $"No se encontró el pago #{paymentId} para eliminar."));
            }
        }
        catch (Exception e)
        {
            ToastService.Notify(new(ToastType.Danger, $"Ocurrió un error al tratar de eliminar el pago: {e.Message}"));
        }
        StateHasChanged();
    }
}
