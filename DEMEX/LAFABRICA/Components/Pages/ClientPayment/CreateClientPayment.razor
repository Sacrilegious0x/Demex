@page "/pagos/registrar"
@using LAFABRICA.Data.DB
@using LAFABRICA.Models.Interface
@using System.ComponentModel.DataAnnotations // Necesario para ValidationMessage
@using System.IO // Necesario para manejo de archivos
@using Microsoft.AspNetCore.Hosting // Necesario para IWebHostEnvironment

@inject IClientPaymentService paymentService
@inject IOrderService orderService // Para obtener la lista de órdenes
@inject NavigationManager NavigationManager
@inject ToastService ToastService
@inject IWebHostEnvironment Environment // Para obtener wwwroot

<PageTitle>Registrar Nuevo Pago</PageTitle>

<Toasts class="p-3" Autohide="true" Delay="4000" Placement="ToastsPlacement.TopRight" />

@if (activeOrders == null)
{
    <div class="text-center p-4">
        <Spinner Color="SpinnerColor.Primary" />
        <p class="mt-2">Cargando órdenes activas...</p>
    </div>
}
else
{
    <EditForm EditContext="@editContext" OnValidSubmit="HandleValidSubmit">
        <DataAnnotationsValidator />
        <Card>
            <CardHeader>
                <CardTitle Size="HeadingSize.H5"><Icon Name="IconName.CashCoin" /> Registrar Nuevo Pago</CardTitle>
            </CardHeader>
            <CardBody>
                <ValidationSummary class="alert alert-danger mb-3" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Orden Asociada *</label>
                        <InputSelect @bind-Value="newPayment.OrderId" class="form-select">
                            <option value="0">-- Seleccione una orden --</option>
                            @foreach (var order in activeOrders)
                            {
                                <option value="@order.Id">Orden #@order.Id (@order.Client?.Name)</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="@(() => newPayment.OrderId)" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Fecha del Pago *</label>
                        <InputDate @bind-Value="newPayment.PaymentDate" class="form-control" />
                        <ValidationMessage For="@(() => newPayment.PaymentDate)" />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Monto (₡) *</label>
                        <InputNumber @bind-Value="newPayment.Amount" class="form-control" />
                        <ValidationMessage For="@(() => newPayment.Amount)" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Método de Pago *</label>
                        <InputSelect @bind-Value="newPayment.PaymentMethod" class="form-select">
                            <option value="">-- Seleccione un método --</option>
                            <option value="Transferencia">Transferencia</option>
                            <option value="SINPE">SINPE</option>
                            <option value="Efectivo">Efectivo</option>
                            <option value="Tarjeta">Tarjeta</option>
                        </InputSelect>
                        <ValidationMessage For="@(() => newPayment.PaymentMethod)" />
                    </div>
                </div>

                <div class="row">
                    <div class="col-12 mb-3">
                        <label class="form-label">Comprobante (Opcional, solo imágenes)</label>
                        <InputFile OnChange="LoadFile" class="form-control" accept="image/*" />
                        @if (!string.IsNullOrEmpty(fileUploadMessage))
                        {
                            <small class="form-text @(selectedFile != null && !fileUploadMessage.StartsWith("Error") ? "text-success" : "text-danger")">
                                @fileUploadMessage
                            </small>
                        }
                    </div>
                </div>

            </CardBody>
            <CardFooter>
                <div class="d-flex justify-content-end gap-2">
                    <a href="/pagos" class="btn btn-light border">Cancelar</a>
                    <button type="submit" class="btn btn-primary">
                        <Icon Name="IconName.Save" /> Guardar Pago
                    </button>
                </div>
            </CardFooter>
        </Card>
    </EditForm>
}

@code {
    private ClientPayment newPayment = new();
    private EditContext editContext = default!;
    private List<Order>? activeOrders; // Lista para el desplegable de órdenes

    // --- Variables para subida de archivo ---
    private IBrowserFile? selectedFile;
    private string? fileUploadMessage;
    private long maxFileSize = 1024 * 1024 * 5; // Límite de 5 MB
    private string[] permittedImageTypes = { "image/jpeg", "image/png", "image/gif", "image/bmp" };
    // ----------------------------------------

    protected override async Task OnInitializedAsync()
    {
        // Inicializar fecha a hoy por defecto
        newPayment.PaymentDate = DateOnly.FromDateTime(DateTime.Today);
        // Inicializar EditContext
        editContext = new EditContext(newPayment);

        // Cargar órdenes activas para el desplegable
        try
        {
            var allOrders = await orderService.GetAllOrders();
            // Filtramos las que no estén finalizadas
            activeOrders = allOrders.Where(o => o.State != "Finalizada")
                                    .OrderByDescending(o => o.Id) // Mostrar más nuevas primero
                                    .ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando órdenes activas: {ex.Message}");
            ToastService.Notify(new(ToastType.Danger, "Error", "No se pudieron cargar las órdenes para asociar el pago."));
            activeOrders = new List<Order>(); // Evitar error null
        }
    }

    /// <summary>
    /// Maneja la selección de un archivo desde el InputFile
    /// </summary>
    private void LoadFile(InputFileChangeEventArgs e)
    {
        selectedFile = null; // Reiniciar
        fileUploadMessage = null;

        var file = e.File;
        if (file == null)
            return;

        // Validar tamaño
        if (file.Size > maxFileSize)
        {
            fileUploadMessage = $"Error: El archivo excede el límite de {maxFileSize / 1024 / 1024} MB.";
            return;
        }

        // Validar tipo de contenido (MIME type)
        if (!permittedImageTypes.Contains(file.ContentType))
        {
            fileUploadMessage = "Error: Por favor, seleccione un archivo de imagen válido (JPG, PNG, GIF, BMP).";
            return;
        }

        selectedFile = file;
        fileUploadMessage = $"Archivo seleccionado: {selectedFile.Name} ({selectedFile.Size / 1024} KB)";
    }


    /// <summary>
    /// Maneja el envío del formulario válido
    /// </summary>
    private async Task HandleValidSubmit()
    {
        // 1. Manejar la subida del archivo si se seleccionó uno
        if (selectedFile != null)
        {
            try
            {
                // Ruta de destino: wwwroot/images/payments
                var webRootPath = Environment.WebRootPath;
                var relativePath = Path.Combine("images", "payments");
                var absolutePath = Path.Combine(webRootPath, relativePath);

                // Asegurarse que el directorio exista
                Directory.CreateDirectory(absolutePath);

                // Crear un nombre de archivo único para evitar colisiones
                var fileExtension = Path.GetExtension(selectedFile.Name);
                var uniqueFileName = $"{Guid.NewGuid()}{fileExtension}";
                var fullFilePath = Path.Combine(absolutePath, uniqueFileName);

                // Guardar el archivo en el servidor (stream)
                await using var fs = new FileStream(fullFilePath, FileMode.Create);
                await selectedFile.OpenReadStream(maxFileSize).CopyToAsync(fs);

                // Guardar la *ruta relativa* en el modelo para la BD
                // Usar / para compatibilidad web
                newPayment.PhotoVoucherUrl = Path.Combine(relativePath, uniqueFileName).Replace("\\", "/");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error al guardar archivo: {ex}");
                ToastService.Notify(new(ToastType.Danger, "Error de Archivo", $"No se pudo guardar el comprobante: {ex.Message}"));
                return; // Detener el proceso si el archivo no se pudo guardar
            }
        }

        // 2. Continuar con el guardado del pago (lógica original)
        try
        {
            await paymentService.CreatePayment(newPayment);
            ToastService.Notify(new(ToastType.Success, "Pago Registrado", $"El pago de {newPayment.Amount:C} ha sido guardado exitosamente."));
            NavigationManager.NavigateTo("/pagos"); // Redirigir a la lista de pagos
        }
        catch (KeyNotFoundException knfex) // Error específico si la orden no existe
        {
            ToastService.Notify(new(ToastType.Danger, "Error de Orden", knfex.Message));
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al guardar pago: {ex}"); // Log del error completo
            ToastService.Notify(new(ToastType.Danger, "Error", $"No se pudo guardar el pago: {ex.Message}"));
        }
    }
}