@page "/pagos/registrar"
@attribute [Authorize]
@using LAFABRICA.Data.DB
@using LAFABRICA.Models
@using LAFABRICA.Models.Interface
@using LAFABRICA.Services.Auth
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using System.ComponentModel.DataAnnotations
@using System.IO
@using Microsoft.AspNetCore.Hosting

@inject IClientPaymentService paymentService
@inject IOrderService orderService
@inject NavigationManager NavigationManager
@inject ToastService ToastService
@inject IWebHostEnvironment Environment

<PageTitle>Registrar Nuevo Pago</PageTitle>

<Toasts class="p-3" Autohide="true" Delay="4000" Placement="ToastsPlacement.TopRight" />

@if (user == null)
{
    <div class="text-center p-5">
        <Spinner Color="SpinnerColor.Primary" />
        <p>Cargando autenticación...</p>
    </div>
}
else if (!HasPermission("Clients_Payments", DemexClaims.Create))
{
    <Alert Color="AlertColor.Warning" class="mt-4">
        <Icon Name="IconName.ExclamationTriangleFill" class="me-2" />
        <strong>No tienes permiso</strong> para registrar nuevos pagos.
    </Alert>
}
else if (activeOrders == null)
{
    <div class="text-center p-4">
        <Spinner Color="SpinnerColor.Primary" />
        <p class="mt-2">Cargando órdenes activas...</p>
    </div>
}
else
{
    <EditForm EditContext="@editContext" OnValidSubmit="HandleValidSubmit">
        <DataAnnotationsValidator />
        <Card>
            <CardHeader class="d-flex justify-content-between align-items-center mt-3">
                <CardTitle Size="HeadingSize.H2"><Icon Name="IconName.CashCoin" /> Registrar Nuevo Pago</CardTitle>
                <a class="btn btn-outline-secondary" href="/pagos">
                    <Icon Name="IconName.ArrowLeft" />
                </a>
            </CardHeader>

            <CardBody>
                <ValidationSummary class="alert alert-danger mb-3" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Orden Asociada *</label>
                        <InputSelect @bind-Value="newPayment.OrderId" class="form-select">
                            <option value="0">-- Seleccione una orden --</option>
                            @foreach (var order in activeOrders)
                            {
                                <option value="@order.Id">Orden #@order.Id (@order.Client?.Name)</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="@(() => newPayment.OrderId)" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Fecha del Pago *</label>
                        <InputDate @bind-Value="newPayment.PaymentDate" class="form-control" />
                        <ValidationMessage For="@(() => newPayment.PaymentDate)" />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Monto (₡) *</label>
                        <InputNumber @bind-Value="newPayment.Amount" class="form-control" />
                        <ValidationMessage For="@(() => newPayment.Amount)" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Método de Pago *</label>
                        <InputSelect @bind-Value="newPayment.PaymentMethod" class="form-select">
                            <option value="">-- Seleccione un método --</option>
                            <option value="Transferencia">Transferencia</option>
                            <option value="SINPE">SINPE</option>
                            <option value="Efectivo">Efectivo</option>
                            <option value="Tarjeta">Tarjeta</option>
                        </InputSelect>
                        <ValidationMessage For="@(() => newPayment.PaymentMethod)" />
                    </div>
                </div>

                <div class="row">
                    <div class="col-12 mb-3">
                        <label class="form-label">Comprobante (Opcional, solo imágenes)</label>
                        <InputFile OnChange="LoadFile" class="form-control" accept="image/*" />
                        @if (!string.IsNullOrEmpty(fileUploadMessage))
                        {
                            <small class="form-text @(selectedFile != null && !fileUploadMessage.StartsWith("Error") ? "text-success" : "text-danger")">
                                @fileUploadMessage
                            </small>
                        }
                    </div>
                </div>

            </CardBody>

            <CardFooter>
                <div class="d-flex justify-content-end gap-2">
                    <a href="/pagos" class="btn btn-outline-secondary border">Cancelar</a>
                    <button type="submit" class="btn btn-primary">
                        Guardar
                    </button>
                </div>
            </CardFooter>
        </Card>
    </EditForm>
}

@code {
    // === Autenticación y permisos ===
    [CascadingParameter] private Task<AuthenticationState>? authenticationStateTask { get; set; }
    private ClaimsPrincipal? user;

    private bool HasPermission(string module, string action)
        => user?.HasClaim($"can_{module.ToUpper()}_{action}", "True") ?? false;

    private ClientPayment newPayment = new();
    private EditContext editContext = default!;
    private List<Order>? activeOrders;

    // --- Subida de archivo ---
    private IBrowserFile? selectedFile;
    private string? fileUploadMessage;
    private long maxFileSize = 1024 * 1024 * 5; // 5 MB
    private string[] permittedImageTypes = { "image/jpeg", "image/png", "image/gif", "image/bmp" };

    protected override async Task OnInitializedAsync()
    {
        var authState = await authenticationStateTask!;
        user = authState.User;

        newPayment.PaymentDate = DateOnly.FromDateTime(DateTime.Today);
        editContext = new EditContext(newPayment);

        try
        {
            var allOrders = await orderService.GetAllOrders();
            activeOrders = allOrders
                .Where(o => o.State != "Finalizada")
                .OrderByDescending(o => o.Id)
                .ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando órdenes activas: {ex.Message}");
            ToastService.Notify(new(ToastType.Danger, "Error", "No se pudieron cargar las órdenes."));
            activeOrders = new List<Order>();
        }
    }

    private void LoadFile(InputFileChangeEventArgs e)
    {
        selectedFile = null;
        fileUploadMessage = null;

        var file = e.File;
        if (file == null)
            return;

        if (file.Size > maxFileSize)
        {
            fileUploadMessage = $"Error: El archivo excede el límite de {maxFileSize / 1024 / 1024} MB.";
            return;
        }

        if (!permittedImageTypes.Contains(file.ContentType))
        {
            fileUploadMessage = "Error: Seleccione una imagen válida (JPG, PNG, GIF, BMP).";
            return;
        }

        selectedFile = file;
        fileUploadMessage = $"Archivo seleccionado: {selectedFile.Name} ({selectedFile.Size / 1024} KB)";
    }

    private async Task HandleValidSubmit()
    {
        if (!HasPermission("Clients_Payments", DemexClaims.Create))
        {
            ToastService.Notify(new(ToastType.Warning, "Sin permiso", "No tienes permiso para registrar pagos."));
            return;
        }

        if (selectedFile != null)
        {
            try
            {
                var webRootPath = Environment.WebRootPath;
                var relativePath = Path.Combine("images", "payments");
                var absolutePath = Path.Combine(webRootPath, relativePath);

                Directory.CreateDirectory(absolutePath);

                var extension = Path.GetExtension(selectedFile.Name);
                var uniqueFileName = $"{Guid.NewGuid()}{extension}";
                var fullPath = Path.Combine(absolutePath, uniqueFileName);

                await using var fs = new FileStream(fullPath, FileMode.Create);
                await selectedFile.OpenReadStream(maxFileSize).CopyToAsync(fs);

                newPayment.PhotoVoucherUrl = Path.Combine(relativePath, uniqueFileName).Replace("\\", "/");
            }
            catch (Exception ex)
            {
                ToastService.Notify(new(ToastType.Danger, "Error de Archivo", $"No se pudo guardar el comprobante: {ex.Message}"));
                return;
            }
        }

        try
        {
            await paymentService.CreatePayment(newPayment);
            ToastService.Notify(new(ToastType.Success, "Pago Registrado", $"El pago de {newPayment.Amount:C} se guardó correctamente."));
            NavigationManager.NavigateTo("/pagos");
        }
        catch (KeyNotFoundException knfex)
        {
            ToastService.Notify(new(ToastType.Danger, "Error de Orden", knfex.Message));
        }
        catch (Exception ex)
        {
            ToastService.Notify(new(ToastType.Danger, "Error", $"No se pudo guardar el pago: {ex.Message}"));
        }
    }
}
