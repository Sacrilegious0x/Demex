@page "/Supplier"
@using BlazorBootstrap
@using LAFABRICA.Models
@using LAFABRICA.Services
@inject ISupplierService SupplierService
@inject NavigationManager NavigationManager


@* --- Estructura HTML (Razor) --- *@
<div class="card shadow-sm h-100 d-flex flex-column">
    <div class="card-header p-4 border-bottom">

        @* Título y Botón de Creación (Gestión de Proveedores) *@
        <div class="d-flex align-items-center justify-content-between mb-3">
            <h1 class="h4 card-title text-gray-900">Gestión de Proveedores</h1>
            <div class="d-flex space-x-2">
                <button class="btn btn-sm text-white"
                        style="background-color: #0f54a1;"
                        @onclick="NavigateToCreate">
                    <i class="bi bi-plus-lg me-2"></i>
                    Nuevo Proveedor
                </button>
            </div>
        </div>

        @* Barra de Búsqueda *@
        <div class="d-flex align-items-center">
            <div class="input-group flex-fill max-w-md">
                <span class="input-group-text bg-white border-end-0">
                    <i class="bi bi-search text-gray-400"></i>
                </span>
                <input type="text"
                       class="form-control border-start-0"
                       placeholder="Buscar proveedores por nombre, contacto, ID o dirección..."
                       value="@searchTerm"
                       @oninput="HandleSearch" />
            </div>
        </div>
    </div>

    @* Área de la Tabla (Similar a flex-1 overflow-auto) *@
    <div class="flex-grow-1 overflow-auto">

        @if (suppliers == null)
        {
            <div class="p-4 text-center">
                <p><em>Cargando proveedores...</em></p>
            </div>
        }
        else
        {
            <table class="table table-striped table-hover table-sm">
                <thead class="table-light">
                    <tr>
                        <th class="font-weight-bold text-gray-900 textalign=center ">Nombre</th>
                        <th class="font-weight-bold text-gray-900">Teléfono</th>
                        <th class="font-weight-bold text-gray-900">Correo</th>
                        <th class="font-weight-bold text-gray-900">Última Compra</th>
                        <th class="font-weight-bold text-gray-900">Notas adicionales</th>
                        <th class="font-weight-bold text-gray-900">Dirección</th>
                        <th class="font-weight-bold text-gray-900 text-end">Acciones</th>
                    </tr>
                </thead>

                <tbody>
                    @if (FilteredSuppliers.Count == 0)
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4 text-muted">
                                No se encontraron proveedores
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var supplier in FilteredSuppliers)
                        {
                            <tr class="hover:bg-gray-50 m-1">
                                <td class="font-weight-bold ">@supplier.Name</td>
                                <td>@supplier.Phone</td>
                                <td>@supplier.Email</td>
                                <td>@(supplier.DateLastPurchase.HasValue? supplier.DateLastPurchase.Value.ToShortDateString() : "N/A")</td>
                                <td class="max-w-xs text-truncate">@supplier.Notes</td> @* Usamos text-truncate de Bootstrap para el overflow *@
                                <td>@supplier.Address</td>

                                <td class="text-end">
                                    <div class="d-flex justify-content-center space-x-2">
                                        <button class="btn btn-lg btn-light  p-0 text-primary"
                                                @onclick="() => HandleEdit(supplier)">
                                            <i class="bi bi-pencil-square h-4 w-4"></i>
                                        </button>
                                        <button class="btn btn-lg btn-light p-0 text-danger"
                                                @onclick="() => { /* Lógica de eliminación */ }">
                                            <i class="bi bi-trash-fill h-4 w-4"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        }
    </div>


    <div class="card-footer p-3 border-top bg-light">

    </div>
</div>


@code {

    private List<SupplierDto>? suppliers;
    private string searchTerm = string.Empty;

    // Propiedad calculada para simular el filtro de React (filteredSuppliers)
    private List<SupplierDto> FilteredSuppliers => 
        suppliers?.Where(s => 
            s.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
            s.Phone.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
            s.Email.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
            s.Address.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)
        ).ToList() ?? new List<SupplierDto>();

    protected override async Task OnInitializedAsync()
    {
        // Obtiene datos directamente del servicio (ya sin HTTP)
        suppliers = await SupplierService.GetSuppliersAsync();
    }

    private void NavigateToCreate()
    {
        // Simula la apertura de un formulario de creación
        NavigationManager.NavigateTo("/Supplier/create");
    }

    private void HandleEdit(SupplierDto supplier)
    {
        // Simula la navegación a la página de edición
        NavigationManager.NavigateTo($"/Supplier/edit/{supplier.Id}");
    }

    private void HandleSearch(ChangeEventArgs e)
    {
        // Actualiza el término de búsqueda y fuerza la re-renderización
        searchTerm = e.Value?.ToString() ?? string.Empty;
    }


}
