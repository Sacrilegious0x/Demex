@page "/change-pass"
@attribute [Authorize]
@using LAFABRICA.Services.Auth
@using Microsoft.AspNetCore.Components.Authorization
@inject DemexAuthService AuthService
@inject DemexAuthenticationStateProvider AuthProvider
@inject NavigationManager nav

<PageTitle>Cambiar Contraseña</PageTitle>

<div class="container mt-5" style="max-width: 500px;">
    <h3 class="text-center mb-4">Cambiar Contraseña</h3>

    <EditForm Model="@model" OnValidSubmit="HandleChangePassword">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label for="current" class="form-label">Contraseña actual</label>
            <InputText id="current" type="password" class="form-control" @bind-Value="model.CurrentPassword" />
        </div>

        <div class="mb-3">
            <label for="new" class="form-label">Nueva contraseña</label>
            <InputText id="new" type="password" class="form-control" @bind-Value="model.NewPassword" />
            <span class="text-black-50">La contraseña debe ser de al menos 8 caracteres</span><br />
            <span class="text-black-50">La contraseña debe incluir letras y números</span>
        </div>

        <div class="mb-3">
            <label for="confirm" class="form-label">Confirmar nueva contraseña</label>
            <InputText id="confirm" type="password" class="form-control" @bind-Value="model.ConfirmPassword" />
            <span class="text-black-50">La contraseña debe ser identica</span>
        </div>

        <button type="submit" class="btn btn-primary w-100">Guardar</button>

        @if (!string.IsNullOrEmpty(message))
        {
            <div class="alert @alertClass mt-3">@message</div>
        }
    </EditForm>
</div>

@code {
    private ChangePasswordModel model = new();
    private string? message;
    private string alertClass = "alert-info";

    private async Task HandleChangePassword()
    {
        try
        {
            if (model.NewPassword != model.ConfirmPassword)
            {
                message = "Las contraseñas nuevas no coinciden.";
                alertClass = "alert-warning";
                return;
            }
            if (!PasswordValidator.IsValid(model.NewPassword))
            {
                message = "La contraseña debe tener al menos 8 caracteres, incluir letras y números.";
            }

            var authState = await AuthProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity == null || !user.Identity.IsAuthenticated)
            {
                message = "Debes iniciar sesión.";
                alertClass = "alert-danger";
                return;
            }

            var userId = int.Parse(user.FindFirst("UserId")!.Value);

            await AuthService.ChangePassword(userId, model.CurrentPassword, model.NewPassword);
            message = "Contraseña actualizada correctamente.";
            alertClass = "alert-success";

            StateHasChanged();

            await Task.Delay(3000);
            nav.NavigateTo("/login");
            
        }
        catch (Exception ex)
        {
            message = ex.Message;
            alertClass = "alert-danger";

        }
        
    }

    public class ChangePasswordModel
    {
        public string CurrentPassword { get; set; } = string.Empty;
        public string NewPassword { get; set; } = string.Empty;
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
