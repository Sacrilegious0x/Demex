@page "/reset-password/{Token}"
@attribute [AllowAnonymous]
@using LAFABRICA.Services.Auth
@inject DemexAuthService AuthService
@inject NavigationManager nav

<PageTitle>Restablecer contraseña</PageTitle>

<div class="container mt-5" style="max-width:400px;">
    <h3 class="text-center mb-4">Restablecer contraseña</h3>

    <EditForm Model="@model" OnValidSubmit="HandleResetPassword">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label class="form-label">Nueva contraseña</label>
            <InputText class="form-control" type="password" @bind-Value="model.NewPassword" />
            <span class="text-black-50">La contraseña debe ser de al menos 8 caracteres</span><br />
            <span class="text-black-50">La contraseña debe incluir letras y números</span>
        </div>
        <div class="mb-3">
            <label class="form-label">Confirmar contraseña</label>
            <InputText class="form-control" type="password" @bind-Value="model.ConfirmPassword" />
            <span class="text-black-50">La contraseña debe ser identica</span>
        </div>

        <button type="submit" class="btn btn-primary w-100">Guardar</button>

        @if (!string.IsNullOrEmpty(message))
        {
            <div class="alert @alertClass mt-3">@message</div>
        }
    </EditForm>
</div>

@code {
    [Parameter] public string Token { get; set; } = string.Empty;
    private ResetModel model = new();
    private string? message;
    private string alertClass = "alert-info";

    private async Task HandleResetPassword()
    {
        try
        {
            if (model.NewPassword != model.ConfirmPassword)
            {
                message = "Las contraseñas no coinciden.";
                alertClass = "alert-warning";
                return;
            }

            if (!PasswordValidator.IsValid(model.NewPassword))
            {
                message = "La contraseña debe tener al menos 8 caracteres, incluir letras y números.";
            }

                await AuthService.ResetPasswordAsync(Uri.UnescapeDataString(Token), model.NewPassword);
                message = "Contraseña restablecida correctamente. Ya puedes iniciar sesión.";
                alertClass = "alert-success";
               
                StateHasChanged();
                await Task.Delay(3000);
                nav.NavigateTo("/login");
            }
            catch (Exception ex)
            {
                message = ex.Message;
                alertClass = "alert-danger";
            }
            
        }

        private class ResetModel
        {
            public string NewPassword { get; set; } = string.Empty;
            public string ConfirmPassword { get; set; } = string.Empty;
        }
    }

