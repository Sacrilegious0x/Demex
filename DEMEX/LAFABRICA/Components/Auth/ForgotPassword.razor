@page "/forgot-password"
@using LAFABRICA.Services.Auth
@attribute [AllowAnonymous]
@inject DemexAuthService AuthService
@inject NavigationManager nav;

<PageTitle>Recuperar contraseña</PageTitle>

<div class="container mt-5" style="max-width:400px;">
    <h3 class="text-center mb-4">Recuperar contraseña</h3>

    <EditForm Model="@model" OnValidSubmit="HandleForgotPassword">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label class="form-label">Correo electrónico</label>
            <InputText class="form-control" @bind-Value="model.Email" />
        </div>

        <button type="submit" class="btn btn-primary w-100">Enviar enlace</button>

        @if (!string.IsNullOrEmpty(message))
        {
            <div class="alert @alertClass mt-3">@message</div>
        }
    </EditForm>
</div>

@code {
    private ForgotPasswordModel model = new();
    private string? message;
    private string alertClass = "alert-info";

    private async Task HandleForgotPassword()
    {
        try
        {
            await AuthService.GeneratePasswordResetAsync(model.Email);
            message = "Si el correo está registrado, te enviaremos un enlace para restablecer tu contraseña.";
            alertClass = "alert-success";
          

        }
        catch (Exception ex)
        {
            message = ex.Message;
            alertClass = "alert-danger";
        }
        StateHasChanged();
        await Task.Delay(3000);
        nav.NavigateTo("/login");
    }

    private class ForgotPasswordModel
    {
        public string Email { get; set; } = string.Empty;
    }
}
