@inherits LayoutComponentBase

<div class="d-flex flex-column min-vh-100">

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg bg-white shadow-sm border-bottom">
        <div class="container-fluid">
            <!-- Brand -->
            <a class="navbar-brand fw-bold d-flex align-items-center" href="/">
                <img src="/Demex.ico" alt="Logo Demex" width="80" height="80" class="me-2" />
            </a>

            <!-- Toggle button (móvil) -->
            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#mainNav"
                    aria-controls="mainNav"
                    aria-expanded="false"
                    aria-label="Alternar navegación">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Links -->
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
                            <i class="bi bi-house-door-fill"></i> Inicio
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/clientes">
                            <i class="bi bi-people-fill"></i> Clientes
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/products">
                            <i class="bi bi-box-seam-fill"></i> Productos
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/orders">
                            <i class="bi bi-cart-fill"></i> Pedidos
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/Supplier">
                            <i class="bi bi-cart-fill"></i> Proveedores
                        </NavLink>
                    </li>
                </ul>

                <!-- Usuario -->
                <div class="d-flex align-items-center">
                    <span class="navbar-text me-3 text-dark">
                        <i class="bi bi-person-circle"></i> Bienvenido
                    </span>
                    <button class="btn btn-outline-dark btn-sm">
                        <i class="bi bi-box-arrow-right"></i> Salir
                    </button>
                </div>
            </div>
        </div>
    </nav>

    <!-- Contenido principal -->
    <main class="flex-grow-1">
        <div class="container py-4">
            @Body
        </div>
    </main>

    <!-- Footer -->
    @* <footer class="bg-dark text-white text-center py-3 mt-auto">
        <div class="container">
            <small>&copy; 2025 DEMEX - Todos los derechos reservados</small><br />
            <small>&copy; 2025 InfoPapus - Todos los derechos reservados</small>
        </div>
    </footer> *@
</div>
