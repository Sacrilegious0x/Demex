@using BlazorBootstrap
@inherits LayoutComponentBase

<div class="d-flex flex-column min-vh-100">

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg bg-white shadow-sm border-bottom">
        <div class="container-fluid">
            <!-- Brand -->
            <a class="navbar-brand fw-bold d-flex align-items-center" href="/">
                <img src="/Demex.ico" alt="Logo Demex" width="80" height="80" class="me-2" />                
            </a>

            <!-- Toggle button (móvil) -->
            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#mainNav"
                    aria-controls="mainNav"
                    aria-expanded="false"
                    aria-label="Alternar navegación">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Links -->
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">

                            <i class="bi bi-house-door-fill me-1"></i> Inicio

                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/clientes">
                            <i class="bi bi-people-fill me-1"></i> Clientes
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/productos">
                            <i class="bi bi-box-seam-fill me-1"></i> Productos
                        </NavLink>
                    </li>
                    
                    <li class="nav-item">
                        <NavLink class="nav-link " href="/ordenes">
                            <i class="bi bi-cart-fill me-1"></i> Órdenes
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link " href="/proveedor">
                            <i class="bi bi-truck me-1"></i> Proveedores
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link disabled" href="/inventory">
                            <i class="bi bi-archive-fill me-1"></i> Inventario
                        </NavLink>
                    </li>

                   
                    
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/pagos">
                            <i class="bi bi-credit-card-fill me-1"></i> Pagos
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link disabled" href="/reports">
                            <i class="bi bi-bar-chart-line-fill me-1"></i> Reportes
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link disabled" href="/tours">
                            <i class="bi bi-signpost-split-fill me-1"></i> Giras
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link disabled" href="/users">
                            <i class="bi bi-person-badge-fill me-1"></i> Usuarios

                        </NavLink>
                    </li>
                </ul>

                <!-- Usuario -->
                <div class="d-flex align-items-center">
                    <span class="navbar-text me-3 text-dark">
                        @* <i class="bi bi-person-circle"></i> Bienvenido *@
                        <i class="bi bi-tux"></i> Bienvenido
                    </span>

                </div>
            </div>
        </div>
    </nav>

    <!-- Contenido principal -->
    <main class="flex-grow-1">
        <div class="container py-4">
            @Body
        </div>
    </main>

    <!-- Footer -->

    <footer class="bg-dark text-white text-center py-3 mt-auto">
        <div class="container">
            <small>&copy; 2025 DEMEX - Todos los derechos reservados</small><br />
            <small>&copy; 2025 InfoPapus - Todos los derechos reservados</small>
        </div>
    </footer> 

</div>
